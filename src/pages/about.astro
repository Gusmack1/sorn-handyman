---
import BaseLayout from '../layouts/BaseLayout.astro';
import Breadcrumbs from '../components/Breadcrumbs.astro';
import TrustStrip from '../components/TrustStrip.astro';
import CTABlock from '../components/CTABlock.astro';
import { BASE } from '../data/business';

const title = 'About Sorn Handyman Services | Fraser and Aidan, East Ayrshire';
const description = 'Fraser and Aidan run Sorn Handyman Services from the village of Sorn in East Ayrshire. Joinery, plumbing, painting, flat-pack, gutters, fencing and general repairs.';
---
<BaseLayout title={title} description={description} canonicalPath="/about/">
  <Breadcrumbs trail={[{ name: 'Home', href: `${BASE}/` }, { name: 'About' }]} />
  <article class="container-x py-12 max-w-3xl prose-sorn">
    <span class="eyebrow">Who we are</span>
    <h1 class="mt-3 font-serif text-5xl font-black text-navy-900">One van. One phone number.</h1>

    <p class="mt-6 text-lg">
      Sorn Handyman Services is Fraser and Aidan, a father-and-son team based in the village of Sorn, East Ayrshire. We cover the Irvine and Ayr valleys from Kilmarnock to Troon and the towns in between, seven days a week.
    </p>

    <h2>Fraser</h2>
    <p>
      Fraser leads on joinery. He hangs doors, frames stud walls, fits kitchens and takes on the tiling, rendering, slating, slabbing and decking that sit alongside. If it needs a saw or a spirit level, the job goes to Fraser.
    </p>

    <h2>Aidan</h2>
    <p>
      Aidan handles the water side of the business, the flat-pack builds and the paperwork. Quotes, invoices, WhatsApp replies and the late-night tap calls come through him.
    </p>

    <h2>Always on the phone</h2>
    <p>
      We answer every call, day or night. A burst pipe at 11pm is not a Monday job. A broken window on Christmas Eve is not a January job. The number on the van is a real phone, and one of us has it on us.
    </p>
    <p>
      If the job can wait until morning, we book you in and go back to sleep. If it cannot, we are in the van. Either way, you get a real voice and a clear answer in under a minute.
    </p>

    <h2>How we quote</h2>
    <ul>
      <li>Send a photo on WhatsApp for a <strong>ballpark price within the hour</strong>.</li>
      <li>Site visit and <strong>written fixed-price quote</strong> for any job over £200.</li>
      <li>No call-out fee. We charge once we are on the tools.</li>
    </ul>

    <h2>Local</h2>
    <p>
      We live in Sorn. Most of our customers are within a 10-mile drive. You are hiring two people who walk the same high street you do.
    </p>
    <p>
      For a job, call Fraser on <a href="tel:+447900255876">07900 255876</a> or WhatsApp Aidan on <a href="https://wa.me/447472223323">07472 223323</a>. Whoever is closer will be there first.
    </p>
  </article>
  <TrustStrip />
  <CTABlock heading="Need a job done? One call to Fraser or Aidan." />
</BaseLayout>

---
import BaseLayout from '../../layouts/BaseLayout.astro';
import Breadcrumbs from '../../components/Breadcrumbs.astro';
import ServiceCard from '../../components/ServiceCard.astro';
import CTABlock from '../../components/CTABlock.astro';
import TrustStrip from '../../components/TrustStrip.astro';
import { services, BASE } from '../../data/business';

const title = 'Handyman Services — Sorn, Mauchline, Kilmarnock, Ayr | 14 Trades, One Call';
const description = 'Guttering, joinery, plumbing, painting, roofing, power-washing, slabbing, fencing, decking, flat-pack, property maintenance, general repairs — 24/7 across East Ayrshire.';
---
<BaseLayout title={title} description={description} canonicalPath="/services/">
  <Breadcrumbs trail={[{ name: 'Home', href: `${BASE}/` }, { name: 'Services' }]} />
  <section class="container-x py-12">
    <span class="eyebrow">Services · 14 trades</span>
    <h1 class="mt-3 font-serif text-5xl font-black text-navy-900 max-w-3xl">Fourteen trades. One number. Any hour.</h1>
    <p class="mt-4 text-lg text-navy-900/75 max-w-2xl">Broken, loose, sagging, leaking, cracked, stuck — or just needs building from scratch. It’s probably on the list below. Bundle two or three into one visit and you save the second call-out fee. If it isn’t on the list, ring us anyway — nine times out of ten it’s still our job.</p>

    <div class="mt-10 grid gap-4 sm:grid-cols-2 lg:grid-cols-3">
      {services.map((s) => <ServiceCard service={s} />)}
    </div>
  </section>
  <TrustStrip />
  <CTABlock />
</BaseLayout>

---
import BaseLayout from '../../layouts/BaseLayout.astro';
import Breadcrumbs from '../../components/Breadcrumbs.astro';
import ServiceCard from '../../components/ServiceCard.astro';
import CTABlock from '../../components/CTABlock.astro';
import TrustStrip from '../../components/TrustStrip.astro';
import { services, BASE } from '../../data/business';

const title = 'Handyman Services — Sorn, Mauchline, Kilmarnock, Ayr | Sorn Handyman Services';
const description = 'Joinery, plumbing, painting, flat-pack, gutters, fencing, decking, power-washing, slabbing, roofing, property maintenance and general repairs across East Ayrshire. Call 07900 255876.';
---
<BaseLayout title={title} description={description} canonicalPath="/services/">
  <Breadcrumbs trail={[{ name: 'Home', href: `${BASE}/` }, { name: 'Services' }]} />
  <section class="container-x py-12">
    <span class="eyebrow">Services</span>
    <h1 class="mt-3 font-serif text-5xl font-black text-navy-900 max-w-3xl">What we cover.</h1>
    <p class="mt-4 text-lg text-navy-900/75 max-w-2xl">We’re handymen — joinery, plumbing, painting, gutters, flat-pack, fencing, decking, roofing, the lot. The list below is a starting point, not the limit. If you don’t see your job, call Fraser on 07900 255876 and he’ll tell you straight whether we can help.</p>

    <div class="mt-10 grid gap-4 sm:grid-cols-2 lg:grid-cols-3">
      {services.map((s) => <ServiceCard service={s} />)}
    </div>
  </section>
  <TrustStrip />
  <CTABlock />
</BaseLayout>

---
import BaseLayout from '../../layouts/BaseLayout.astro';
import Breadcrumbs from '../../components/Breadcrumbs.astro';
import CTABlock from '../../components/CTABlock.astro';
import AreaCard from '../../components/AreaCard.astro';
import TrustStrip from '../../components/TrustStrip.astro';
import FAQ from '../../components/FAQ.astro';
import SchemaBlock from '../../components/SchemaBlock.astro';
import RelatedPosts from '../../components/RelatedPosts.astro';
import { services, areas, BASE, business } from '../../data/business';
import { serviceSchema, faqSchema } from '../../lib/schema';
import { postsBySlugs, SERVICE_POSTS, SERVICE_POSTS_FALLBACK } from '../../data/posts';

export function getStaticPaths() {
  return services.map((s) => ({ params: { slug: s.slug }, props: { service: s } }));
}

const { service } = Astro.props;
const canonical = `/services/${service.slug}/`;
const canonicalUrl = `${business.siteUrl}${canonical}`;

const title = `${service.name} — Sorn Handyman Services | East Ayrshire`;
const description = `${service.short} Covering Sorn, Mauchline, Kilmarnock, Ayr, Troon, Irvine and the rest of East Ayrshire. Call Fraser on 07900 255876.`;

// Page-level FAQ (service-specific). Minimum 5 Qs per service.
// Covers the themes customers actually ask on the phone:
// how we quote, speed, KA postcode coverage, weekends, materials.
const pageFaqs = [
  {
    q: `How do I get a quote for ${service.name.toLowerCase()}?`,
    a: `Phone Fraser on 07900 255876 or WhatsApp a photo to Aidan on 07472 223323 — we provide a free no-obligation quote for every job. Every job is priced individually.`,
  },
  {
    q: `How quickly can you come out for ${service.name.toLowerCase()}?`,
    a: `Small jobs, usually within a few days. Larger projects, a week or two. We guarantee a response to every enquiry.`,
  },
  {
    q: `Do you cover KA postcodes for ${service.name.toLowerCase()}?`,
    a: 'Yes. Standard coverage is the full KA patch — KA1 Kilmarnock, KA3 Stewarton and Kilmaurs, KA4 Galston, KA5 Sorn, Mauchline, Catrine, KA7 Ayr, KA9 Prestwick, KA10 Troon, KA12 Irvine, KA18 Cumnock, Auchinleck, Muirkirk, KA19 Maybole. Further afield by arrangement.',
  },
  {
    q: `Do you work weekends?`,
    a: 'We answer the phone and book jobs across the week. Phone or WhatsApp to arrange a time that suits.',
  },
  {
    q: `Do you supply the materials for ${service.name.toLowerCase()}?`,
    a: `Yes — by default we supply everything in the quote and you get one invoice. If you prefer to supply your own materials that is fine too. Tell us when you call and we will price labour only.`,
  },
  {
    q: `No job too small?`,
    a: `Correct — no job too small. Phone 07900 255876 or WhatsApp 07472 223323 for a free no-obligation quote.`,
  },
];

const schemas = [
  serviceSchema(service.slug, canonicalUrl),
  faqSchema(pageFaqs),
].filter(Boolean);

// Topically relevant blog posts for this service (2-3).
const relatedPostSlugs = SERVICE_POSTS[service.slug] ?? SERVICE_POSTS_FALLBACK;
const relatedPosts = postsBySlugs(relatedPostSlugs).slice(0, 3);
---
<BaseLayout title={title} description={description} canonicalPath={canonical} extraSchema={schemas}>
  <Breadcrumbs trail={[
    { name: 'Home', href: `${BASE}/` },
    { name: 'Services', href: `${BASE}/services/` },
    { name: service.name },
  ]} />

  <section class="container-x py-12 grid lg:grid-cols-5 gap-10">
    <div class="lg:col-span-3">
      <span class="eyebrow">{service.icon} {service.name}</span>
      <h1 class="mt-3 font-serif text-5xl font-black text-navy-900">{service.name} across East Ayrshire</h1>
      <p class="mt-4 text-lg text-navy-900/80 leading-relaxed">{service.description}</p>

      <div class="mt-6 flex flex-wrap gap-3">
        <a href={`tel:${business.phoneE164}`} class="btn-primary" aria-label={`Call Fraser on ${business.phone}`}>Call Fraser {business.phone}</a>
        <a href={`https://wa.me/${business.whatsapp.replace('+','')}?text=Hi%2C%20I%20need%20a%20quote%20for%20${encodeURIComponent(service.name)}`} class="btn-secondary bg-[#25D366] !text-white hover:!bg-[#1fb858]" aria-label={`WhatsApp Aidan a photo of your ${service.name} job`}>WhatsApp Aidan a photo</a>
        <a href={`${BASE}/quote/`} class="btn-secondary" aria-label="Get a free no-obligation quote">Get a free quote</a>
        <a href={`${BASE}/pricing/`} class="btn-ghost" aria-label="How we quote">How we quote</a>
      </div>
      <p class="mt-4 text-sm text-navy-900/70">
        <a href={`${BASE}/gallery/`} class="font-semibold text-amber-700 hover:underline">See real {service.name.toLowerCase()} job photos in our gallery →</a>
      </p>

      <h2 class="mt-12 font-serif text-3xl font-bold text-navy-900">What’s included</h2>
      <ul class="mt-4 grid gap-2">
        {service.included.map((i) => (
          <li class="flex gap-3 text-navy-900/80"><span class="mt-1.5 h-2 w-2 shrink-0 rounded-full bg-amber-500"></span>{i}</li>
        ))}
      </ul>

      {service.notIncluded && service.notIncluded.length > 0 && (
        <>
          <h2 class="mt-10 font-serif text-3xl font-bold text-navy-900">What we don’t do</h2>
          <ul class="mt-4 grid gap-2">
            {service.notIncluded.map((i) => (
              <li class="flex gap-3 text-navy-900/60"><span class="mt-1.5 h-2 w-2 shrink-0 rounded-full bg-navy-900/20"></span>{i}</li>
            ))}
          </ul>
        </>
      )}

      <div class="mt-10 card bg-amber-500/10 border border-amber-500/30">
        <p class="font-serif text-xl font-bold text-navy-900">Free no-obligation quote</p>
        <p class="mt-2 text-sm text-navy-900/70">Every job priced individually. Prices depend on parts, access and time — phone or WhatsApp for a free quote.</p>
      </div>
    </div>

    <aside class="lg:col-span-2">
      <div class="card sticky top-20">
        <h2 class="font-serif text-2xl font-bold text-navy-900">Towns we cover</h2>
        <ul class="mt-3 grid grid-cols-2 gap-1.5 text-sm">
          {areas.map((a) => (
            <li><a class="text-navy-900/80 hover:text-amber-600" href={`${BASE}/areas/${a.slug}/`}>✓ {a.name}</a></li>
          ))}
        </ul>
        <hr class="my-5 border-navy-900/10" />
        <h3 class="font-serif text-lg font-bold text-navy-900">How we quote</h3>
        <ol class="mt-2 grid gap-2 text-sm text-navy-900/80 list-decimal pl-5">
          <li>WhatsApp a photo to {business.whatsappDisplay}</li>
          <li>We guarantee a response to every enquiry</li>
          <li>Free no-obligation quote — every job priced individually</li>
          <li>Phone or WhatsApp to book</li>
        </ol>
      </div>
    </aside>
  </section>

  <RelatedPosts
    posts={relatedPosts}
    eyebrow={`Read more on ${service.name.toLowerCase()}`}
    heading={`More on ${service.name.toLowerCase()} from our blog`}
    variant="plain"
  />

  <!-- Related areas -->
  <section class="bg-navy-50/60 border-y border-navy-900/5 cv-auto">
    <div class="container-x py-16">
      <div class="max-w-2xl">
        <span class="eyebrow">Where we do {service.name.toLowerCase()}</span>
        <h2 class="mt-4 font-serif text-3xl font-bold text-navy-900">{service.name} across Ayrshire. Eleven towns covered.</h2>
      </div>
      <div class="mt-8 grid gap-4 sm:grid-cols-2 lg:grid-cols-3">
        {areas.slice(0,6).map((a) => <AreaCard area={a} />)}
      </div>
    </div>
  </section>

  <FAQ faqs={pageFaqs} heading={`${service.name} — your questions`} />
  <TrustStrip />
  <CTABlock heading={`Book ${service.name.toLowerCase()} across Ayrshire.`} />
</BaseLayout>

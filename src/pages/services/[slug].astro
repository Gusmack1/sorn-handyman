---
import BaseLayout from '../../layouts/BaseLayout.astro';
import Breadcrumbs from '../../components/Breadcrumbs.astro';
import CTABlock from '../../components/CTABlock.astro';
import AreaCard from '../../components/AreaCard.astro';
import TrustStrip from '../../components/TrustStrip.astro';
import FAQ from '../../components/FAQ.astro';
import SchemaBlock from '../../components/SchemaBlock.astro';
import { services, areas, BASE, business } from '../../data/business';
import { serviceSchema, faqSchema } from '../../lib/schema';

export function getStaticPaths() {
  return services.map((s) => ({ params: { slug: s.slug }, props: { service: s } }));
}

const { service } = Astro.props;
const canonical = `/services/${service.slug}/`;
const canonicalUrl = `${business.siteUrl}${canonical}`;

const title = `${service.name} — Sorn Handyman Services | 24/7 East Ayrshire`;
const description = `${service.short} Covering Sorn, Mauchline, Kilmarnock, Ayr, Troon, Irvine and across East Ayrshire. Call 07900 255876 anytime.`;

// Page-level FAQ (service-specific, pulled from service description + universals)
const pageFaqs = [
  {
    q: `How quickly can you start a ${service.name.toLowerCase()} job?`,
    a: service.priceFrom
      ? `For small ${service.name.toLowerCase()} jobs (under 2 hours) we can usually be on site within 24–48 hours. Emergencies, any time. Bigger projects — 1 to 2 weeks from written quote.`
      : `Small jobs within 24–48 hours, bigger ones 1–2 weeks from quote. Emergencies any time.`,
  },
  {
    q: `Do you cover my area for ${service.name.toLowerCase()}?`,
    a: 'Standard coverage is Sorn, Mauchline, Cumnock, Catrine, Auchinleck, Muirkirk, Galston, Kilmarnock, Ayr, Troon and Irvine. We travel further by arrangement — give us a ring.',
  },
  {
    q: `Do I need to be home?`,
    a: 'Not usually, once we\'ve agreed the job. Many of our repeat customers leave a key or give us the gate code. We\'ll send photos on completion either way.',
  },
  {
    q: `How do you quote for ${service.name.toLowerCase()}?`,
    a: `${service.priceFrom ? `${service.name} starts from ${service.priceFrom}. ` : ''}Send a photo on WhatsApp and we\'ll give you a ballpark within the hour. Site visit and a written fixed-price quote follows for anything over £200.`,
  },
  {
    q: `Are you insured?`,
    a: 'Yes — £2m public liability. Certificate on request.',
  },
];

const schemas = [
  serviceSchema(service.slug, canonicalUrl),
  faqSchema(pageFaqs),
].filter(Boolean);
---
<BaseLayout title={title} description={description} canonicalPath={canonical} extraSchema={schemas}>
  <Breadcrumbs trail={[
    { name: 'Home', href: `${BASE}/` },
    { name: 'Services', href: `${BASE}/services/` },
    { name: service.name },
  ]} />

  <section class="container-x py-12 grid lg:grid-cols-5 gap-10">
    <div class="lg:col-span-3">
      <span class="eyebrow">{service.icon} {service.name}</span>
      <h1 class="mt-3 font-serif text-5xl font-black text-navy-900">{service.name} across East Ayrshire — 24/7.</h1>
      <p class="mt-4 text-lg text-navy-900/80 leading-relaxed">{service.description}</p>

      <div class="mt-6 flex flex-wrap gap-3">
        <a href={`tel:${business.phoneE164}`} class="btn-primary">📞 Call {business.phone}</a>
        <a href={`https://wa.me/${business.whatsapp.replace('+','')}?text=Hi%2C%20I%20need%20a%20quote%20for%20${encodeURIComponent(service.name)}`} class="btn-secondary bg-[#25D366] !text-white hover:!bg-[#1fb858]">💬 WhatsApp a photo</a>
        <a href={`${BASE}/quote/`} class="btn-secondary">Free written quote →</a>
      </div>

      <h2 class="mt-12 font-serif text-3xl font-bold text-navy-900">What\u2019s included</h2>
      <ul class="mt-4 grid gap-2">
        {service.included.map((i) => (
          <li class="flex gap-3 text-navy-900/80"><span class="mt-1.5 h-2 w-2 shrink-0 rounded-full bg-amber-500"></span>{i}</li>
        ))}
      </ul>

      {service.notIncluded && service.notIncluded.length > 0 && (
        <>
          <h2 class="mt-10 font-serif text-3xl font-bold text-navy-900">What we don\u2019t do</h2>
          <ul class="mt-4 grid gap-2">
            {service.notIncluded.map((i) => (
              <li class="flex gap-3 text-navy-900/60"><span class="mt-1.5 h-2 w-2 shrink-0 rounded-full bg-navy-900/20"></span>{i}</li>
            ))}
          </ul>
        </>
      )}

      {service.priceFrom && (
        <div class="mt-10 card bg-amber-500/10 border border-amber-500/30">
          <p class="text-sm text-amber-700">Starting from</p>
          <p class="mt-1 font-serif text-4xl font-black text-navy-900">{service.priceFrom}</p>
          <p class="mt-2 text-sm text-navy-900/70">Fixed-price written quote on any job over £200. No call-out fee for quotes in East Ayrshire.</p>
        </div>
      )}
    </div>

    <aside class="lg:col-span-2">
      <div class="card sticky top-20">
        <h2 class="font-serif text-2xl font-bold text-navy-900">We cover</h2>
        <ul class="mt-3 grid grid-cols-2 gap-1.5 text-sm">
          {areas.map((a) => (
            <li><a class="text-navy-900/80 hover:text-amber-600" href={`${BASE}/areas/${a.slug}/`}>✓ {a.name}</a></li>
          ))}
        </ul>
        <hr class="my-5 border-navy-900/10" />
        <h3 class="font-serif text-lg font-bold text-navy-900">How we quote</h3>
        <ol class="mt-2 grid gap-2 text-sm text-navy-900/80 list-decimal pl-5">
          <li>WhatsApp a photo to {business.whatsappDisplay}</li>
          <li>Ballpark price back within the hour</li>
          <li>Site visit &amp; written fixed price for anything over £200</li>
          <li>Booked within 48 hours, emergencies now</li>
        </ol>
      </div>
    </aside>
  </section>

  <!-- Related areas -->
  <section class="bg-navy-50/60 border-y border-navy-900/5">
    <div class="container-x py-16">
      <div class="max-w-2xl">
        <span class="eyebrow">Where we do {service.name.toLowerCase()}</span>
        <h2 class="mt-4 font-serif text-3xl font-bold text-navy-900">Local {service.name.toLowerCase()} — 11 towns covered.</h2>
      </div>
      <div class="mt-8 grid gap-4 sm:grid-cols-2 lg:grid-cols-3">
        {areas.slice(0,6).map((a) => <AreaCard area={a} />)}
      </div>
    </div>
  </section>

  <FAQ faqs={pageFaqs} heading={`${service.name} — your questions`} />
  <TrustStrip />
  <CTABlock heading={`Need ${service.name.toLowerCase()}? Call us anytime.`} />
</BaseLayout>

---
import BaseLayout from '../layouts/BaseLayout.astro';
import Breadcrumbs from '../components/Breadcrumbs.astro';
import BeforeAfter from '../components/BeforeAfter.astro';
import CTABlock from '../components/CTABlock.astro';
import { BASE } from '../data/business';

const title = 'Before & After Gallery | Sorn Handyman Services';
const description = 'Real jobs, real photos. Drag the slider to see before and after — gutters, decking, fencing, power-washing across East Ayrshire.';

// Placeholder slots — replace src with real JPGs as they land.
const jobs = [
  { label: 'Gutter replacement — Mauchline', before: `${BASE}/img/placeholder-before.svg`, after: `${BASE}/img/placeholder-after.svg` },
  { label: 'Driveway power-wash — Cumnock', before: `${BASE}/img/placeholder-before.svg`, after: `${BASE}/img/placeholder-after.svg` },
  { label: 'Fence replacement — Galston', before: `${BASE}/img/placeholder-before.svg`, after: `${BASE}/img/placeholder-after.svg` },
  { label: 'Decking — Kilmarnock', before: `${BASE}/img/placeholder-before.svg`, after: `${BASE}/img/placeholder-after.svg` },
  { label: 'Kitchen fit — Ayr', before: `${BASE}/img/placeholder-before.svg`, after: `${BASE}/img/placeholder-after.svg` },
  { label: 'Slabbing — Catrine', before: `${BASE}/img/placeholder-before.svg`, after: `${BASE}/img/placeholder-after.svg` },
  { label: 'Flat-pack (IKEA PAX) — Troon', before: `${BASE}/img/placeholder-before.svg`, after: `${BASE}/img/placeholder-after.svg` },
  { label: 'Painting & Decorating — Auchinleck', before: `${BASE}/img/placeholder-before.svg`, after: `${BASE}/img/placeholder-after.svg` },
];
---
<BaseLayout title={title} description={description} canonicalPath="/gallery/">
  <Breadcrumbs trail={[{ name: 'Home', href: `${BASE}/` }, { name: 'Gallery' }]} />
  <section class="container-x py-12">
    <span class="eyebrow">Before &amp; after</span>
    <h1 class="mt-3 font-serif text-5xl font-black text-navy-900 max-w-3xl">Drag the slider. See the difference.</h1>
    <p class="mt-4 text-lg text-navy-900/75 max-w-2xl">Real jobs from real East Ayrshire houses. Some are archive photos, some are last week’s.</p>

    <div class="mt-10 grid gap-6 md:grid-cols-2">
      {jobs.map((j) => (
        <div>
          <BeforeAfter before={j.before} after={j.after} label={j.label} />
          <p class="mt-2 text-sm font-medium text-navy-900/70">{j.label}</p>
        </div>
      ))}
    </div>
  </section>
  <CTABlock heading="Got a job like one of these?" />
</BaseLayout>

---
import BaseLayout from '../layouts/BaseLayout.astro';
import { BASE } from '../data/business';

const title = 'Page not found — Sorn Handyman Services';
const description = 'That page does not exist. Head back to the home page, browse our services, or request a free no-obligation quote.';
---
<BaseLayout title={title} description={description} canonicalPath="/404/" noindex>
  <section class="container-x py-24 text-center">
    <span class="eyebrow">404</span>
    <h1 class="mt-3 font-serif text-6xl font-black text-navy-900">Page not found</h1>
    <p class="mt-4 text-lg text-navy-900/70 max-w-2xl mx-auto">
      The page you were looking for has moved or never existed. Try one of the links below, or give Fraser or Aidan a ring and we will point you the right way.
    </p>

    <div class="mt-10 flex flex-wrap justify-center gap-3">
      <a href={`${BASE}/`} class="btn-primary">Back to home</a>
      <a href={`${BASE}/services/`} class="btn-outline">Browse services</a>
      <a href={`${BASE}/quote/`} class="btn-outline">Get a free quote</a>
    </div>
  </section>
</BaseLayout>

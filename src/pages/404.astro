---
import BaseLayout from '../layouts/BaseLayout.astro';
import { services, areas, BASE } from '../data/business';

const title = 'Page not found — Sorn Handyman Services';
const description = 'That page doesn\'t exist. Try one of our services or areas, or call 07900 255876 anytime.';
---
<BaseLayout title={title} description={description} canonicalPath="/404/" noindex>
  <section class="container-x py-24 text-center">
    <span class="eyebrow">404</span>
    <h1 class="mt-3 font-serif text-6xl font-black text-navy-900">That page is on a job elsewhere.</h1>
    <p class="mt-4 text-lg text-navy-900/70 max-w-2xl mx-auto">Try one of these instead, or just call us — that usually works.</p>

    <div class="mt-10 grid gap-6 sm:grid-cols-2 max-w-3xl mx-auto text-left">
      <div class="card">
        <h2 class="font-serif text-2xl font-bold text-navy-900">Popular services</h2>
        <ul class="mt-3 space-y-2 text-navy-900/80">
          {services.slice(0,6).map((s) => (
            <li>• <a class="hover:text-amber-600 underline-offset-2 hover:underline" href={`${BASE}/services/${s.slug}/`}>{s.name}</a></li>
          ))}
        </ul>
      </div>
      <div class="card">
        <h2 class="font-serif text-2xl font-bold text-navy-900">Your town</h2>
        <ul class="mt-3 space-y-2 text-navy-900/80">
          {areas.slice(0,6).map((a) => (
            <li>• <a class="hover:text-amber-600 underline-offset-2 hover:underline" href={`${BASE}/areas/${a.slug}/`}>Handyman {a.name}</a></li>
          ))}
        </ul>
      </div>
    </div>

    <div class="mt-10">
      <a href={`${BASE}/`} class="btn-secondary">← Back home</a>
    </div>
  </section>
</BaseLayout>

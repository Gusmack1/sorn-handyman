---
import BaseLayout from '../../layouts/BaseLayout.astro';
import Breadcrumbs from '../../components/Breadcrumbs.astro';
import { business, BASE } from '../../data/business';

const title = 'Leave us a Google review — Sorn Handyman Services';
const description = 'Thanks for trusting Fraser and Aidan. A 30-second Google review makes a massive difference to a small local firm in East Ayrshire.';

const googleReviewUrl = 'https://g.page/r/CZryRT85fFQ1EBI/review';
const whatsappReview = `https://wa.me/447472223323?text=${encodeURIComponent('Hi, I want to leave a review or feedback')}`;
---
<BaseLayout title={title} description={description} canonicalPath="/reviews/leave-a-review/">
  <Breadcrumbs trail={[{ name: 'Home', href: `${BASE}/` }, { name: 'Reviews', href: `${BASE}/reviews/` }, { name: 'Leave a review' }]} />

  <section class="container-x py-12 max-w-3xl">
    <span class="eyebrow">Thank you</span>
    <h1 class="mt-3 font-serif text-5xl font-black text-navy-900">Thanks — leave us a Google review</h1>
    <p class="mt-4 text-lg text-navy-900/75">
      Cheers for trusting us with the job. A 30-second review on Google makes a massive difference to a small local firm like ours.
    </p>

    <div class="mt-8 card bg-navy-900 text-white">
      <p class="font-serif text-2xl font-bold">One tap — Google review form</p>
      <p class="mt-2 text-white/75">The button below opens the Google review form for our profile. A star rating and a line or two about the job is plenty.</p>
      <a
        href={googleReviewUrl}
        rel="noopener"
        target="_blank"
        class="mt-5 inline-flex btn-primary btn-lg"
        aria-label="Open the Google review form for Sorn Handyman Services"
      >
        Open Google review form
      </a>
    </div>

    <div class="mt-6 card">
      <p class="font-serif text-xl font-bold text-navy-900">Prefer WhatsApp?</p>
      <p class="mt-2 text-navy-900/75">Send Aidan a quick message and we will sort it from there — handy if the Google sign-in is being awkward on your phone.</p>
      <a
        href={whatsappReview}
        rel="noopener"
        target="_blank"
        class="mt-4 inline-flex btn-secondary"
        aria-label="Send feedback to Aidan on WhatsApp"
      >
        WhatsApp Aidan — 07472 223323
      </a>
    </div>

    <div class="mt-10 card">
      <h2 class="font-serif text-2xl font-bold text-navy-900">What to say if you are stuck</h2>
      <p class="mt-2 text-navy-900/75">Not sure what to write? Answer any one of these and you have a cracking review.</p>
      <ul class="mt-4 grid gap-3 text-navy-900/85">
        <li class="flex items-start gap-3">
          <span aria-hidden="true" class="mt-1 inline-flex h-6 w-6 flex-none items-center justify-center rounded-full bg-amber-500 text-navy-900 font-bold text-sm">1</span>
          <span>What job did we do for you?</span>
        </li>
        <li class="flex items-start gap-3">
          <span aria-hidden="true" class="mt-1 inline-flex h-6 w-6 flex-none items-center justify-center rounded-full bg-amber-500 text-navy-900 font-bold text-sm">2</span>
          <span>How was the communication from Fraser and Aidan?</span>
        </li>
        <li class="flex items-start gap-3">
          <span aria-hidden="true" class="mt-1 inline-flex h-6 w-6 flex-none items-center justify-center rounded-full bg-amber-500 text-navy-900 font-bold text-sm">3</span>
          <span>Would you book us again?</span>
        </li>
      </ul>
    </div>

    <div class="mt-6 card border-l-4 border-amber-500">
      <h2 class="font-serif text-2xl font-bold text-navy-900">If something was not right</h2>
      <p class="mt-2 text-navy-900/75">
        We are a father-and-son team and we read every message personally. If any part of the job was not right, please WhatsApp Aidan on
        <a href={`https://wa.me/${business.whatsapp.replace('+', '')}`} class="font-semibold text-navy-900 underline decoration-amber-500 underline-offset-2">07472 223323</a>
        <strong> before </strong>
        leaving a negative review, so we can come back and put it right. We would much rather fix it than leave you unhappy.
      </p>
    </div>

    <div class="mt-10 flex flex-wrap gap-3">
      <a href={`${BASE}/`} class="btn-ghost">Back to the home page</a>
      <a href={`${BASE}/reviews/`} class="btn-ghost">See our reviews page</a>
    </div>
  </section>
</BaseLayout>

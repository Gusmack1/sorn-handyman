---
import BaseLayout from '../layouts/BaseLayout.astro';
import Breadcrumbs from '../components/Breadcrumbs.astro';
import CTABlock from '../components/CTABlock.astro';
import { business, BASE, services } from '../data/business';

const title = 'Pricing — Sorn Handyman Services | Ayrshire';
const description = 'Every job priced individually. Phone or WhatsApp for a free no-obligation quote — prices depend on parts, access and time on the day.';
---
<BaseLayout title={title} description={description} canonicalPath="/pricing/">
  <Breadcrumbs trail={[{ name: 'Home', href: `${BASE}/` }, { name: 'Pricing' }]} />

  <section class="container-x py-12 max-w-4xl">
    <span class="eyebrow">Pricing · Ayrshire</span>
    <h1 class="mt-3 font-serif text-5xl font-black text-navy-900">Every job priced individually.</h1>
    <p class="mt-4 text-lg text-navy-900/80 leading-relaxed">
      We don't publish set rates because no two jobs are the same — prices depend on parts, access and time on the day. Phone or WhatsApp for a free no-obligation quote. No job too small. We guarantee a response to every enquiry.
    </p>

    <div class="mt-10 card">
      <h2 class="font-serif text-2xl font-bold text-navy-900">How to get a quote</h2>
      <ol class="mt-4 grid gap-3 text-navy-900/80 list-decimal pl-5">
        <li><strong>Phone</strong> — call Fraser on {business.phone}. We guarantee a response to every enquiry.</li>
        <li><strong>WhatsApp pictures</strong> — send photos to Aidan on {business.whatsappDisplay}. We come back on the same thread.</li>
        <li><strong>Free no-obligation quote</strong> — every job priced individually before we start.</li>
      </ol>
    </div>

    <h2 class="mt-12 font-serif text-3xl font-bold text-navy-900">What we cover</h2>
    <p class="mt-3 text-navy-900/75">Fraser and Aidan — a Sorn-based team covering East Ayrshire and into South and North Ayrshire.</p>

    <div class="mt-6 grid gap-3 sm:grid-cols-2">
      {services.map((s) => (
        <a href={`${BASE}/services/${s.slug}/`} class="card hover:shadow-elev-2 transition">
          <p class="font-serif text-lg font-bold text-navy-900">{s.icon} {s.name}</p>
          <p class="mt-1 text-sm text-navy-900/70">{s.short}</p>
        </a>
      ))}
    </div>

    <div class="mt-10 card">
      <h2 class="font-serif text-2xl font-bold text-navy-900">What changes the price</h2>
      <ul class="mt-3 grid gap-2 text-navy-900/80">
        <li class="flex gap-3"><span class="mt-1.5 h-2 w-2 shrink-0 rounded-full bg-amber-500"></span><span><strong>Parts.</strong> The tap, bracket, panel or board you need.</span></li>
        <li class="flex gap-3"><span class="mt-1.5 h-2 w-2 shrink-0 rounded-full bg-amber-500"></span><span><strong>Access.</strong> Tight closes, upper-floor flats and awkward back-garden gates.</span></li>
        <li class="flex gap-3"><span class="mt-1.5 h-2 w-2 shrink-0 rounded-full bg-amber-500"></span><span><strong>Condition.</strong> A seized valve or a rotted fence post adds work.</span></li>
        <li class="flex gap-3"><span class="mt-1.5 h-2 w-2 shrink-0 rounded-full bg-amber-500"></span><span><strong>Time on site.</strong> Every job is different. That's why we quote individually.</span></li>
      </ul>
    </div>

    <div class="mt-10 card bg-navy-900 text-cream-50">
      <p class="text-cream-50/90 text-lg">Ready for a quote?</p>
      <div class="mt-4 flex flex-wrap gap-3">
        <a href={`tel:${business.phoneE164}`} class="btn-primary" aria-label={`Call Fraser on ${business.phone}`}>Call Fraser {business.phone}</a>
        <a href={`https://wa.me/${business.whatsapp.replace('+','')}?text=Hi%20Sorn%20Handyman%20%E2%80%94%20I%27d%20like%20a%20quote%20for%20a%20job.`} class="btn-ghost btn-lg" target="_blank" rel="noopener" aria-label={`WhatsApp Aidan on ${business.whatsappDisplay}`}>WhatsApp Aidan {business.whatsappDisplay}</a>
        <a href={`${BASE}/quote/`} class="btn-ghost btn-lg">Free no-obligation quote</a>
      </div>
    </div>
  </section>

  <CTABlock heading="Phone or WhatsApp for a free quote." sub="Every job priced individually. No job too small." />
</BaseLayout>

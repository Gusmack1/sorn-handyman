---
import BaseLayout from '../layouts/BaseLayout.astro';
import Breadcrumbs from '../components/Breadcrumbs.astro';
import CTABlock from '../components/CTABlock.astro';
import { business, BASE } from '../data/business';

const title = 'Contact Sorn Handyman Services | Phone, WhatsApp and Form';
const description = 'Call Fraser on 07900 255876 day or night. WhatsApp Aidan on +44 7472 223323 for photo quotes. Send the form and we reply the same day.';

// If PUBLIC_WEB3FORMS_KEY is unset at build time, skip Web3Forms and show phone/WhatsApp fallback.
const hasFormKey = Boolean(business.web3formsKey && business.web3formsKey.length > 0);
---
<BaseLayout title={title} description={description} canonicalPath="/contact/">
  <Breadcrumbs trail={[{ name: 'Home', href: `${BASE}/` }, { name: 'Contact' }]} />
  <section class="container-x py-12 grid gap-10 lg:grid-cols-5">
    <div class="lg:col-span-2">
      <span class="eyebrow">Contact</span>
      <h1 class="mt-3 font-serif text-5xl font-black text-navy-900">Call Fraser or Aidan.</h1>
      <p class="mt-4 text-lg text-navy-900/75">One of us answers every call. Daytime, evening, weekend or three in the morning, you get a real voice and a straight answer.</p>

      <div class="mt-8 space-y-4">
        <a href={`tel:${business.phoneE164}`} class="card flex items-center gap-4 hover:bg-amber-500/5" aria-label={`Call Fraser on ${business.phone}`}>
          <span class="inline-flex h-12 w-12 items-center justify-center rounded-xl bg-amber-500 text-navy-900" aria-hidden="true">
            <svg width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M22 16.92v3a2 2 0 0 1-2.18 2 19.79 19.79 0 0 1-8.63-3.07 19.5 19.5 0 0 1-6-6 19.79 19.79 0 0 1-3.07-8.67A2 2 0 0 1 4.11 2h3a2 2 0 0 1 2 1.72c.13.96.37 1.9.72 2.8a2 2 0 0 1-.45 2.11L8.09 9.91a16 16 0 0 0 6 6l1.28-1.28a2 2 0 0 1 2.11-.45c.9.35 1.84.59 2.8.72A2 2 0 0 1 22 16.92z"/></svg>
          </span>
          <div>
            <p class="text-sm text-navy-900/60">Tap to call Fraser</p>
            <p class="font-serif text-2xl font-bold text-navy-900">{business.phone}</p>
          </div>
        </a>
        <a href={`https://wa.me/${business.whatsapp.replace('+','')}`} class="card flex items-center gap-4 hover:bg-[#25D366]/5" aria-label={`WhatsApp Aidan on ${business.whatsappDisplay}`}>
          <span class="inline-flex h-12 w-12 items-center justify-center rounded-xl bg-[#25D366] text-white" aria-hidden="true">
            <svg width="22" height="22" viewBox="0 0 24 24" fill="currentColor"><path d="M20.5 3.5A11 11 0 0 0 2.9 17l-1.4 5 5.1-1.4A11 11 0 1 0 20.5 3.5zM12 20a8 8 0 0 1-4-1.1l-.3-.2-3 .8.8-2.9-.2-.3A8 8 0 1 1 12 20z"/></svg>
          </span>
          <div>
            <p class="text-sm text-navy-900/60">WhatsApp Aidan — send a photo</p>
            <p class="font-serif text-2xl font-bold text-navy-900">{business.whatsappDisplay}</p>
          </div>
        </a>
        <div class="card flex items-start gap-4">
          <span class="inline-flex h-12 w-12 items-center justify-center rounded-xl bg-navy-900 text-amber-500" aria-hidden="true">
            <svg width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M21 10c0 7-9 13-9 13s-9-6-9-13a9 9 0 0 1 18 0z"/><circle cx="12" cy="10" r="3"/></svg>
          </span>
          <div>
            <p class="text-sm text-navy-900/60">Based in</p>
            <p class="font-serif text-lg font-bold text-navy-900">{business.address.locality}, {business.address.region} {business.address.postalCode}</p>
            <p class="mt-1 text-sm text-navy-900/70">Call-outs across East Ayrshire, and into South and North Ayrshire. No call-out fee.</p>
          </div>
        </div>
        <div class="card flex items-start gap-4">
          <span class="inline-flex h-12 w-12 items-center justify-center rounded-xl bg-navy-900/5 text-navy-900" aria-hidden="true">
            <svg width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><circle cx="12" cy="12" r="10"/><path d="M12 6v6l4 2"/></svg>
          </span>
          <div>
            <p class="text-sm text-navy-900/60">Hours</p>
            <p class="font-serif text-lg font-bold text-navy-900">Open 24 hours, 7 days a week</p>
            <p class="mt-1 text-sm text-navy-900/70">Out-of-hours call-outs between 10pm and 6am carry a £60 minimum, added to the job total.</p>
          </div>
        </div>
      </div>
    </div>

    <div class="lg:col-span-3">
      <div class="card">
        <h2 class="font-serif text-2xl font-bold text-navy-900">Send a message</h2>
        {hasFormKey ? (
          <p class="mt-1 text-sm text-navy-900/60">Form posts straight to our email and WhatsApp. No account needed.</p>
        ) : (
          <p class="mt-1 text-sm text-navy-900/60">The fastest reply is a call or a WhatsApp photo. Buttons below go straight through to Fraser and Aidan.</p>
        )}

        {hasFormKey ? (
        <form
          action="https://api.web3forms.com/submit"
          method="POST"
          class="mt-5 grid gap-4"
        >
          <input type="hidden" name="access_key" value={business.web3formsKey} />
          <input type="hidden" name="subject" value="New lead — sornhandyman.co.uk /contact" />
          <input type="hidden" name="from_name" value="Sorn Handyman website" />
          <input type="checkbox" name="botcheck" class="hidden" style="display:none" tabindex="-1" autocomplete="off" />

          <label class="grid gap-1">
            <span class="text-sm font-medium text-navy-900">Your name</span>
            <input name="name" required aria-required="true" placeholder="First name, last name" title="Tell us your name so we know who to ask for" class="rounded-lg border border-navy-900/15 bg-white px-4 py-2.5 text-base focus:border-amber-500 focus:ring-2 focus:ring-amber-500/20 outline-none" />
          </label>
          <div class="grid gap-4 sm:grid-cols-2">
            <label class="grid gap-1">
              <span class="text-sm font-medium text-navy-900">Phone</span>
              <input name="phone" type="tel" required aria-required="true" placeholder="07xxx xxxxxx" title="Enter a phone number we can reach you on" class="rounded-lg border border-navy-900/15 bg-white px-4 py-2.5 text-base focus:border-amber-500 focus:ring-2 focus:ring-amber-500/20 outline-none" />
            </label>
            <label class="grid gap-1">
              <span class="text-sm font-medium text-navy-900">Email (optional)</span>
              <input name="email" type="email" placeholder="you@example.co.uk" class="rounded-lg border border-navy-900/15 bg-white px-4 py-2.5 text-base focus:border-amber-500 focus:ring-2 focus:ring-amber-500/20 outline-none" />
            </label>
          </div>
          <label class="grid gap-1">
            <span class="text-sm font-medium text-navy-900">Town and postcode</span>
            <input name="location" placeholder="Mauchline, KA5 6JL" class="rounded-lg border border-navy-900/15 bg-white px-4 py-2.5 text-base focus:border-amber-500 focus:ring-2 focus:ring-amber-500/20 outline-none" />
          </label>
          <label class="grid gap-1">
            <span class="text-sm font-medium text-navy-900">What needs doing?</span>
            <textarea name="message" rows="5" required aria-required="true" title="Give us a short description of the job" class="rounded-lg border border-navy-900/15 bg-white px-4 py-2.5 text-base focus:border-amber-500 focus:ring-2 focus:ring-amber-500/20 outline-none" placeholder="A short description is plenty — we'll come back with any questions."></textarea>
          </label>
          <div class="flex items-start gap-2 text-sm text-navy-900/70">
            <input id="urgent" name="urgent" type="checkbox" class="mt-1" />
            <label for="urgent">Urgent — this is an emergency (water, security, fire risk).</label>
          </div>
          <button type="submit" class="btn-primary">Send message to Fraser</button>
          <p class="text-xs text-navy-900/50">We reply inside the hour during the day, inside 2 hours overnight. Sending the form means we can contact you on the phone, email or WhatsApp provided. If it does not send, call Fraser on {business.phone}.</p>
        </form>
        ) : (
        <div class="mt-5 grid gap-3">
          <a href={`tel:${business.phoneE164}`} class="btn-primary w-full text-center" aria-label={`Call Fraser on ${business.phone}`}>Call Fraser {business.phone}</a>
          <a href={`https://wa.me/${business.whatsapp.replace('+','')}`} class="btn-secondary w-full text-center" aria-label={`WhatsApp Aidan on ${business.whatsappDisplay}`}>WhatsApp Aidan {business.whatsappDisplay}</a>
          <p class="text-xs text-navy-900/50">Online form is offline for a moment. Phone and WhatsApp reach Fraser or Aidan fastest.</p>
        </div>
        )}
      </div>

      <div class="mt-4 aspect-video rounded-xl overflow-hidden ring-1 ring-navy-900/10">
        <iframe
          title="Map of Sorn Handyman Services service area"
          src={business.googleMapsEmbed}
          loading="lazy"
          referrerpolicy="no-referrer-when-downgrade"
          class="w-full h-full border-0"
          allowfullscreen
        ></iframe>
      </div>
    </div>
  </section>
  <CTABlock />
</BaseLayout>

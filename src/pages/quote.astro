---
import BaseLayout from '../layouts/BaseLayout.astro';
import Breadcrumbs from '../components/Breadcrumbs.astro';
import { business, BASE, services, areas } from '../data/business';

const title = 'Free Handyman Quote — East Ayrshire | Sorn Handyman Services';
const description = 'Four-step quote form. Pick the service, tell us where, choose a timescale, describe the job. Reply within the hour. No call-out fee.';

// If PUBLIC_WEB3FORMS_KEY is unset at build time, skip Web3Forms and show phone/WhatsApp fallback.
const hasFormKey = Boolean(business.web3formsKey && business.web3formsKey.length > 0);
---
<BaseLayout title={title} description={description} canonicalPath="/quote/">
  <Breadcrumbs trail={[{ name: 'Home', href: `${BASE}/` }, { name: 'Free quote' }]} />
  <section class="container-x py-12 max-w-3xl">
    <span class="eyebrow">Free written quote · no call-out fee</span>
    <h1 class="mt-3 font-serif text-5xl font-black text-navy-900">Tell us what needs doing.</h1>
    <p class="mt-4 text-lg text-navy-900/75">One of us — Fraser or Aidan — will reply with a ballpark within the hour. Written quote inside a day.</p>

    {hasFormKey ? (
    <form
      action="https://api.web3forms.com/submit"
      method="POST"
      class="mt-8 grid gap-8"
      id="quote-form"
    >
      <input type="hidden" name="access_key" value={business.web3formsKey} />
      <input type="hidden" name="subject" value="New quote request — sornhandyman /quote" />
      <input type="hidden" name="from_name" value="Sorn Handyman website" />
      <input type="checkbox" name="botcheck" class="hidden" style="display:none" tabindex="-1" autocomplete="off" />

      <fieldset class="card">
        <legend class="px-2 text-sm font-semibold text-amber-600">Step 1 of 4 — Service</legend>
        <p class="mb-3 text-navy-900/70 text-sm">Pick the closest match. If it’s none of these, pick General repairs and describe it in step 4.</p>
        <div class="grid gap-2 sm:grid-cols-2">
          {services.map((s, i) => (
            <label class="flex items-center gap-2 rounded-lg border border-navy-900/10 px-3 py-2 hover:bg-amber-500/5 cursor-pointer">
              <input type="radio" name="service" value={s.name} required={i===0} class="accent-amber-500" />
              <span class="text-navy-900">{s.icon} {s.name}</span>
            </label>
          ))}
        </div>
      </fieldset>

      <fieldset class="card">
        <legend class="px-2 text-sm font-semibold text-amber-600">Step 2 of 4 — Area</legend>
        <div class="grid gap-4 sm:grid-cols-2">
          <label class="grid gap-1">
            <span class="text-sm font-medium text-navy-900">Which town are you in?</span>
            <select name="town" class="rounded-lg border border-navy-900/15 bg-white px-4 py-2.5 text-base focus:border-amber-500 focus:ring-2 focus:ring-amber-500/20 outline-none">
              {areas.map((a) => (<option value={a.name}>{a.name}</option>))}
              <option value="other">Somewhere else — I'll say below</option>
            </select>
          </label>
          <label class="grid gap-1">
            <span class="text-sm font-medium text-navy-900">Rough postcode (KA something)</span>
            <input name="postcode" class="rounded-lg border border-navy-900/15 bg-white px-4 py-2.5 text-base focus:border-amber-500 focus:ring-2 focus:ring-amber-500/20 outline-none" placeholder="e.g. KA5" />
          </label>
        </div>
      </fieldset>

      <fieldset class="card">
        <legend class="px-2 text-sm font-semibold text-amber-600">Step 3 of 4 — When</legend>
        <div class="grid gap-2 sm:grid-cols-2">
          {['Emergency (now)','Today / tonight','This week','Next 2–4 weeks','Flexible'].map((t) => (
            <label class="flex items-center gap-2 rounded-lg border border-navy-900/10 px-3 py-2 hover:bg-amber-500/5 cursor-pointer">
              <input type="radio" name="timing" value={t} required={t==='Emergency (now)'} class="accent-amber-500" />
              <span class="text-navy-900">{t}</span>
            </label>
          ))}
        </div>
      </fieldset>

      <fieldset class="card">
        <legend class="px-2 text-sm font-semibold text-amber-600">Step 4 of 4 — Describe the job + your details</legend>
        <div class="grid gap-4">
          <label class="grid gap-1">
            <span class="text-sm font-medium text-navy-900">Describe the job (photos help — send on WhatsApp after)</span>
            <textarea name="message" rows="5" required placeholder="e.g. back garden fence blew down in the storm — 6 panels across 9m, posts probably ok. Want same timber replaced, ideally this weekend." class="rounded-lg border border-navy-900/15 bg-white px-4 py-2.5 text-base focus:border-amber-500 focus:ring-2 focus:ring-amber-500/20 outline-none"></textarea>
          </label>
          <div class="grid gap-4 sm:grid-cols-2">
            <label class="grid gap-1">
              <span class="text-sm font-medium text-navy-900">Your name</span>
              <input name="name" required placeholder="e.g. Morag" class="rounded-lg border border-navy-900/15 bg-white px-4 py-2.5 text-base focus:border-amber-500 focus:ring-2 focus:ring-amber-500/20 outline-none" />
            </label>
            <label class="grid gap-1">
              <span class="text-sm font-medium text-navy-900">Phone we can ring you back on</span>
              <input name="phone" required placeholder="07xxx xxxxxx" class="rounded-lg border border-navy-900/15 bg-white px-4 py-2.5 text-base focus:border-amber-500 focus:ring-2 focus:ring-amber-500/20 outline-none" />
            </label>
          </div>
          <label class="grid gap-1">
            <span class="text-sm font-medium text-navy-900">Email (only if you prefer email)</span>
            <input name="email" type="email" placeholder="you@example.com" class="rounded-lg border border-navy-900/15 bg-white px-4 py-2.5 text-base focus:border-amber-500 focus:ring-2 focus:ring-amber-500/20 outline-none" />
          </label>
        </div>
      </fieldset>

      <div class="flex flex-wrap gap-3 justify-between items-center">
        <p class="text-xs text-navy-900/50">We read every quote request within the hour. No one else gets your details.</p>
        <button type="submit" class="btn-primary text-lg">Send quote request</button>
      </div>
    </form>
    ) : (
    <div class="mt-8 card">
      <h2 class="font-serif text-2xl font-bold text-navy-900">Quickest route: call or WhatsApp</h2>
      <p class="mt-2 text-navy-900/70">Our online form is briefly offline — phone and WhatsApp hit Fraser and Aidan instantly, 24/7.</p>
      <div class="mt-4 grid gap-3 sm:grid-cols-2">
        <a href={`tel:${business.phoneE164}`} class="btn-primary text-center">📞 Call {business.phone}</a>
        <a href={`https://wa.me/${business.whatsapp.replace('+','')}?text=Hi%20Sorn%20Handyman%20%E2%80%94%20I%27d%20like%20a%20quote.`} class="btn-secondary text-center">💬 WhatsApp {business.whatsappDisplay}</a>
      </div>
      <p class="mt-3 text-xs text-navy-900/50">Send a photo on WhatsApp with a short description and we'll reply with a ballpark within the hour.</p>
    </div>
    )}

    <div class="mt-8 card bg-navy-900 text-white">
      <p class="text-white/80">Would rather talk?</p>
      <div class="mt-3 flex flex-wrap gap-3">
        <a href={`tel:${business.phoneE164}`} class="btn-primary">📞 {business.phone}</a>
        <a href={`https://wa.me/${business.whatsapp.replace('+','')}`} class="btn-ghost">💬 WhatsApp {business.whatsappDisplay}</a>
      </div>
    </div>
  </section>
</BaseLayout>

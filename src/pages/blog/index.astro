---
import BaseLayout from '../../layouts/BaseLayout.astro';
import Breadcrumbs from '../../components/Breadcrumbs.astro';
import CTABlock from '../../components/CTABlock.astro';
import { posts } from '../../data/posts';
import { business, BASE } from '../../data/business';

const title = 'Job diary — Sorn Handyman Services';
const description =
  'Recent handyman jobs across Ayrshire — bathroom strip-outs, fencing, decking, plumbing, fascia repairs and more. Every post is a real job Fraser and Aidan have finished.';
const canonicalPath = '/blog/';
const siteUrl = business.siteUrl.replace(/\/$/, '');

const blogSchema = {
  '@context': 'https://schema.org',
  '@type': 'Blog',
  '@id': `${siteUrl}/blog/#blog`,
  name: 'Sorn Handyman Services — Job diary',
  description,
  url: `${siteUrl}/blog/`,
  publisher: { '@id': `${siteUrl}/#business` },
  blogPost: posts.map((p) => ({
    '@type': 'BlogPosting',
    headline: p.title,
    url: `${siteUrl}/blog/${p.slug}/`,
    datePublished: p.date,
    dateModified: p.date,
    author: { '@type': 'Person', name: p.author },
    description: p.description,
    keywords: p.keyword,
    image: `${siteUrl}${p.ogImage}`,
  })),
};
---
<BaseLayout title={title} description={description} canonicalPath={canonicalPath} extraSchema={blogSchema}>
  <Breadcrumbs trail={[{ name: 'Home', href: `${BASE}/` }, { name: 'Blog' }]} />
  <section class="container-x py-12">
    <span class="eyebrow">Job diary · {posts.length} {posts.length === 1 ? 'post' : 'posts'}</span>
    <h1 class="mt-3 font-serif text-5xl font-black text-navy-900 max-w-3xl">Recent jobs from Fraser and Aidan.</h1>
    <p class="mt-4 text-lg text-navy-900/75 max-w-2xl">
      Short notes on real handyman jobs across Ayrshire — what the work was, how we
      tackled it, and a photo from the day.
    </p>

    {posts.length === 0 ? (
      <div class="mt-10 rounded-2xl border border-navy-900/10 bg-navy-50/50 p-8 max-w-2xl">
        <p class="text-navy-900/80 text-lg">
          Our job diary goes live shortly. Meanwhile see recent work on our
          <a class="font-semibold text-amber-700 hover:underline" href={`${BASE}/gallery/`}>gallery</a>.
        </p>
      </div>
    ) : (
      <div class="mt-10 grid gap-6 md:grid-cols-2 lg:grid-cols-3">
        {posts.map((p) => (
          <article class="group relative rounded-2xl border border-navy-900/10 bg-white p-6 shadow-sm transition hover:-translate-y-0.5 hover:shadow-lg">
            <div class="flex flex-wrap items-center gap-2 text-xs font-semibold uppercase tracking-wider text-amber-600">
              <span>{p.area}</span>
              <span aria-hidden class="text-navy-900/20">·</span>
              <span class="text-navy-900/60">{p.readMinutes} min read</span>
            </div>
            <h2 class="mt-3 font-serif text-2xl font-black text-navy-900 leading-tight">
              <a href={`${BASE}/blog/${p.slug}/`} class="after:absolute after:inset-0">{p.title}</a>
            </h2>
            <p class="mt-3 text-navy-900/75">{p.description}</p>
            <div class="mt-5 flex items-center justify-between text-sm">
              <span class="text-navy-900/60">{p.dateDisplay}</span>
              <span class="font-semibold text-amber-600 group-hover:text-amber-700">Read &rarr;</span>
            </div>
          </article>
        ))}
      </div>
    )}
  </section>
  <CTABlock />
</BaseLayout>

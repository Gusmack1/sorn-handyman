---
import BaseLayout from '../../layouts/BaseLayout.astro';
import Breadcrumbs from '../../components/Breadcrumbs.astro';
import { BASE } from '../../data/business';

const title = 'Post retired — Sorn Handyman Services';
const description = 'This post has been retired. See our live job diary or recent work.';
// Canonical points at /blog/ so search engines consolidate ranking signal to the diary.
const canonicalPath = '/blog/';
---
<BaseLayout
  title={title}
  description={description}
  canonicalPath={canonicalPath}
  noindex
>
  <Breadcrumbs trail={[
    { name: 'Home', href: `${BASE}/` },
    { name: 'Blog', href: `${BASE}/blog/` },
    { name: 'Post retired' },
  ]} />
  <section class="container-x py-16 max-w-2xl">
    <h1 class="font-serif text-4xl font-black text-navy-900">Post retired</h1>
    <p class="mt-4 text-lg text-navy-900/80">
      This post has been retired. See our live job diary at
      <a class="font-semibold text-amber-700 hover:underline" href={`${BASE}/blog/`}>/blog/</a>
      or recent work at
      <a class="font-semibold text-amber-700 hover:underline" href={`${BASE}/gallery/`}>/gallery/</a>.
    </p>
  </section>
</BaseLayout>

---
import BaseLayout from '../layouts/BaseLayout.astro';
import Hero from '../components/Hero.astro';
import TrustStrip from '../components/TrustStrip.astro';
import ServiceCard from '../components/ServiceCard.astro';
import AreaCard from '../components/AreaCard.astro';
import FAQ from '../components/FAQ.astro';
import CTABlock from '../components/CTABlock.astro';
import FacebookFeed from '../components/FacebookFeed.astro';
import { services, areas, faqs, BASE } from '../data/business';
import { faqSchema } from '../lib/schema';

const title = 'Sorn Handyman Services — father & son team covering Ayrshire';
const description =
  'Fencing, decking, plumbing, joinery, roofing, landscaping and more across Ayrshire. Father-and-son team — no job too small, free quotes, WhatsApp a photo to 07472 223323.';

// Top 6 services for the home grid (full list lives at /services/)
const featuredServices = services.slice(0, 6);
// Top 6 FAQs (full list shown below)
const featuredFaqs = faqs.slice(0, 6);
---
<BaseLayout
  title={title}
  description={description}
  canonicalPath="/"
  extraSchema={faqSchema(featuredFaqs)}
>
  <Hero />

  <TrustStrip />

  <!-- Services grid (top 6) -->
  <section class="bg-cream-50" id="services">
    <div class="container-site py-16 md:py-24">
      <div class="flex items-end justify-between gap-6 flex-wrap">
        <div class="max-w-2xl">
          <span class="eyebrow">What we do</span>
          <h2 class="mt-4 font-display text-h1 text-navy-800">Fencing, decking, plumbing, joinery, roofing, landscaping — and more.</h2>
          <p class="mt-3 text-navy-500 text-body-lg leading-relaxed">No job too small. If it needs fixing, fitting or freshening up, send Fraser or Aidan a photo on WhatsApp and we will come back with a free quote.</p>
        </div>
        <a href={`${BASE}/services/`} class="btn-outline btn-sm">See all services</a>
      </div>
      <div class="mt-10 grid gap-4 sm:grid-cols-2 lg:grid-cols-3">
        {featuredServices.map((s) => <ServiceCard service={s} />)}
      </div>
    </div>
  </section>

  <!-- About snippet: father + son -->
  <section class="bg-cream-100 border-y border-cream-200">
    <div class="container-site py-16 md:py-24 grid gap-10 lg:grid-cols-[1.1fr_1fr] items-center">
      <div>
        <span class="eyebrow">Father & son</span>
        <h2 class="mt-4 font-display text-h1 text-navy-800">Fraser and Aidan. Two trades, one van, one phone number.</h2>
        <p class="mt-4 text-navy-500 text-body-lg leading-relaxed">
          We are a father-and-son handyman team based in Sorn, East Ayrshire. Every call goes to one of us personally — no call centres, no chains of sub-contractors. We specialise in small repairs and we get to you quickly, but we can also take on larger projects when they come up.
        </p>
        <p class="mt-4 text-navy-500 leading-relaxed">
          Every job on our Facebook page is a real job for a real Ayrshire customer, posted on the day we finished. That is the only marketing we do — the work, and photos of the work.
        </p>
        <div class="mt-8 flex flex-wrap gap-3">
          <a href={`${BASE}/about/`} class="btn-outline btn-sm">More about us</a>
          <a href={`${BASE}/quote/`} class="btn-primary btn-sm">Get a free quote</a>
        </div>
      </div>
      <div class="relative">
        <img
          src={`${BASE}/brand/sorn-logo.png`}
          alt="Sorn Handyman Services logo"
          width="480"
          height="480"
          loading="lazy"
          decoding="async"
          class="mx-auto h-64 w-64 md:h-80 md:w-80 rounded-full object-cover bg-cream-50 ring-1 ring-navy-100 shadow-elev-3 motion-safe:animate-float"
        />
        <div class="absolute -bottom-2 left-1/2 -translate-x-1/2 bg-navy-800 text-cream-50 px-4 py-2 rounded-full text-xs font-semibold uppercase tracking-wide shadow-elev-2">
          Sorn · Ayrshire
        </div>
      </div>
    </div>
  </section>

  <!-- Areas grid (15 pills) -->
  <section class="bg-cream-50" id="areas">
    <div class="container-site py-16 md:py-24">
      <div class="flex items-end justify-between gap-6 flex-wrap">
        <div class="max-w-2xl">
          <span class="eyebrow">Where we work</span>
          <h2 class="mt-4 font-display text-h1 text-navy-800">All of Ayrshire. One van, one phone number.</h2>
          <p class="mt-3 text-navy-500 text-body-lg leading-relaxed">Based in Sorn and working the whole of East Ayrshire plus the coast — Ayr, Troon, Prestwick, Irvine, Kilmarnock, Mauchline and the villages in between.</p>
        </div>
        <a href={`${BASE}/areas/`} class="btn-outline btn-sm">See all areas</a>
      </div>
      <div class="mt-10 grid gap-4 sm:grid-cols-2 lg:grid-cols-3">
        {areas.map((a) => <AreaCard area={a} />)}
      </div>
    </div>
  </section>

  <!-- Facebook proof — real jobs for real Ayrshire customers -->
  <FacebookFeed />

  <!-- FAQ (top 6) -->
  <FAQ faqs={featuredFaqs} />

  <!-- Final CTA -->
  <CTABlock />
</BaseLayout>

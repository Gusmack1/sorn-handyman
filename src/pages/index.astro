---
import BaseLayout from '../layouts/BaseLayout.astro';
import Hero from '../components/Hero.astro';
import TrustStrip from '../components/TrustStrip.astro';
import ServiceCard from '../components/ServiceCard.astro';
import AreaCard from '../components/AreaCard.astro';
import ProcessSteps from '../components/ProcessSteps.astro';
import FAQ from '../components/FAQ.astro';
import CTABlock from '../components/CTABlock.astro';
import TestimonialCard from '../components/TestimonialCard.astro';
import FacebookFeed from '../components/FacebookFeed.astro';
import SchemaBlock from '../components/SchemaBlock.astro';
import { services, areas, faqs, business, BASE } from '../data/business';
import { faqSchema } from '../lib/schema';

const title = '24/7 Handyman East Ayrshire | Sorn Handyman Services — Fraser & Aidan';
const description = 'Father-and-son handyman team in Sorn, Mauchline, Cumnock, Kilmarnock and across East Ayrshire — open 24 hours, 7 days a week. Joinery, plumbing, guttering, fencing, decking. Call 07900 255876 anytime.';
---
<BaseLayout
  title={title}
  description={description}
  canonicalPath="/"
  extraSchema={faqSchema(faqs)}
>
  <Hero />
  <TrustStrip />

  <!-- Services grid -->
  <section class="container-x py-16" id="services">
    <div class="flex items-end justify-between gap-6 flex-wrap">
      <div class="max-w-2xl">
        <span class="eyebrow">14 trades · one number</span>
        <h2 class="mt-4 font-serif text-4xl font-bold text-navy-900">If it’s broken in the house, we’ve probably fixed it before.</h2>
        <p class="mt-3 text-navy-900/70">Sticking bedroom door in a Sorn cottage, full back-garden deck in Mauchline — it’s the same phone number. If it’s on the list, ring us. If it isn’t, ring us anyway and we’ll tell you straight whether it’s ours.</p>
      </div>
      <a href={`${BASE}/services/`} class="btn-secondary !py-2 !px-4 text-sm">See all 14 trades →</a>
    </div>
    <div class="mt-8 grid gap-4 sm:grid-cols-2 lg:grid-cols-3">
      {services.map((s) => <ServiceCard service={s} />)}
    </div>
  </section>

  <!-- Areas grid -->
  <section class="bg-navy-50/60 border-y border-navy-900/5">
    <div class="container-x py-16">
      <div class="flex items-end justify-between gap-6 flex-wrap">
        <div class="max-w-2xl">
          <span class="eyebrow">Where we work</span>
          <h2 class="mt-4 font-serif text-4xl font-bold text-navy-900">Eleven Ayrshire towns — no call-out fee in any of them.</h2>
          <p class="mt-3 text-navy-900/70">We’re in Mauchline, Cumnock and Catrine most working days and out to Ayr, Troon or Kilmarnock inside the hour. If you’re on a farm road between two of those, you’re still in our patch — give us a ring.</p>
        </div>
        <a href={`${BASE}/areas/`} class="btn-secondary !py-2 !px-4 text-sm">See every town we cover →</a>
      </div>
      <div class="mt-8 grid gap-4 sm:grid-cols-2 lg:grid-cols-3">
        {areas.map((a) => <AreaCard area={a} />)}
      </div>
    </div>
  </section>

  <ProcessSteps />

  <FacebookFeed
    title="Recent jobs — straight from Facebook"
    subtitle="Every photo is a real Ayrshire house, posted the day we finished — fences in Galston, gutters in Mauchline, a deck in Kilmarnock. Tap a card to see the original Facebook post."
  />

  <!-- Reviews strip (honest: no reviews yet) -->
  <section class="container-x py-16">
    <div class="max-w-2xl">
      <span class="eyebrow">What customers say</span>
      <h2 class="mt-4 font-serif text-4xl font-bold text-navy-900">New profile, old hands.</h2>
      <p class="mt-3 text-navy-900/70">
        We only set up the Google Business Profile a few weeks ago, so the review count is honestly low. Real ones are landing. In the meantime — ask in Sorn, Mauchline or Cumnock. Someone on the next street will have had us round.
      </p>
    </div>
    <div class="mt-8 grid gap-4 md:grid-cols-3">
      <TestimonialCard
        name="Your review here"
        town="Ayrshire"
        stars={5}
        body="We'd love to hear how we did. Scan the QR on our business card or visit our Google Business Profile after the job."
        job="First 20 reviews get a year-end thank-you coffee voucher"
      />
      <TestimonialCard
        name="Your review here"
        town="East Ayrshire"
        stars={5}
        body="Honest, local, always-on. If we earned it, please tell Google — it helps your neighbours find us."
      />
      <TestimonialCard
        name="Your review here"
        town="KA5"
        stars={5}
        body="Tell us what worked and (just as important) what didn't — we fix things, including ourselves."
      />
    </div>
    <div class="mt-8 text-center">
      <a href={business.gbpUrl} rel="noopener" class="btn-secondary">Leave us a Google review →</a>
    </div>
  </section>

  <FAQ />
  <CTABlock />
</BaseLayout>

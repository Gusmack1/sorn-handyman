---
import BaseLayout from '../layouts/BaseLayout.astro';
import Breadcrumbs from '../components/Breadcrumbs.astro';
import TestimonialCard from '../components/TestimonialCard.astro';
import FacebookFeed from '../components/FacebookFeed.astro';
import CTABlock from '../components/CTABlock.astro';
import { business, BASE } from '../data/business';

const title = 'Reviews — Sorn Handyman Services | East Ayrshire';
const description = 'Leave a Google review for Sorn Handyman Services. Our profile is new and reviews help customers across Ayrshire find us.';
---
<BaseLayout title={title} description={description} canonicalPath="/reviews/">
  <Breadcrumbs trail={[{ name: 'Home', href: `${BASE}/` }, { name: 'Reviews' }]} />
  <section class="container-x py-12 max-w-4xl">
    <span class="eyebrow">Reviews</span>
    <h1 class="mt-3 font-serif text-5xl font-black text-navy-900">Local reviews from a new profile.</h1>
    <p class="mt-4 text-lg text-navy-900/75">
      We opened our Google Business Profile recently, so the review count is still low. If we have worked at your house in Sorn, Mauchline, Cumnock or anywhere else in Ayrshire, a short Google review helps your neighbours find us.
    </p>

    <div class="mt-8 card bg-navy-900 text-white">
      <p class="font-serif text-2xl font-bold">Leave a Google review in 30 seconds</p>
      <p class="mt-2 text-white/75">Tap the button, give us a star rating and a line about the job.</p>
      <a href={business.gbpUrl} rel="noopener" class="mt-4 inline-flex btn-primary">⭐ Leave a review</a>
    </div>

    <div class="mt-10 grid gap-4 md:grid-cols-2">
      <TestimonialCard name="First review goes here" town="Ayrshire" stars={5} body="Your first real review will land on this page and replace this placeholder. Ask Fraser or Aidan for a review card at the end of the job." />
      <TestimonialCard name="Second review goes here" town="East Ayrshire" stars={5} body="We read every review and reply to every one, including the awkward ones." />
    </div>

  </section>

  <FacebookFeed
    title="Recent work, posted to our Facebook the day we finish it"
    subtitle="Until the Google reviews come in, the Facebook feed is our record. Every completed job goes up on the day. No stock photos."
  />

  <section class="container-x py-12 max-w-4xl">
    <!-- GBP reviews embed instructions (for Gus) -->
    <section class="mt-14 prose-sorn">
      <h2>How we display reviews</h2>
      <p>
        Google does not allow direct iframe embedding of the review list. On this page we display verified copy-paste reviews with the reviewer\u2019s first name and last initial, linked back to the Google profile. Once we reach 10 or more reviews we will add an automated widget. Until then every review here is mirrored by hand and dated.
      </p>
    </section>
  </section>
  <CTABlock heading="Leave a review, or book a job. Either helps us." />
</BaseLayout>

---
import BaseLayout from '../layouts/BaseLayout.astro';
import Breadcrumbs from '../components/Breadcrumbs.astro';
import TestimonialCard from '../components/TestimonialCard.astro';
import FacebookFeed from '../components/FacebookFeed.astro';
import CTABlock from '../components/CTABlock.astro';
import { business, BASE } from '../data/business';

const title = 'Reviews — Sorn Handyman Services | Honest & Local';
const description = 'Help your neighbours find us by leaving a Google review. Real reviews are on the way — we only started the profile recently.';
---
<BaseLayout title={title} description={description} canonicalPath="/reviews/">
  <Breadcrumbs trail={[{ name: 'Home', href: `${BASE}/` }, { name: 'Reviews' }]} />
  <section class="container-x py-12 max-w-4xl">
    <span class="eyebrow">Reviews</span>
    <h1 class="mt-3 font-serif text-5xl font-black text-navy-900">Honest, local, new.</h1>
    <p class="mt-4 text-lg text-navy-900/75">
      We only set up the Google Business Profile a few weeks back, so the review count is low — and we’re not going to fake it. If we’ve done a job for you in Sorn, Mauchline, Cumnock, Galston or anywhere else on the patch, thirty seconds on Google helps the next neighbour find us and keeps us honest.
    </p>

    <div class="mt-8 card bg-navy-900 text-white">
      <p class="font-serif text-2xl font-bold">Leave a Google review in thirty seconds</p>
      <p class="mt-2 text-white/75">Tap the button, give us stars and a line about the job. That’s it.</p>
      <a href={business.gbpUrl} rel="noopener" class="mt-4 inline-flex btn-primary">⭐ Leave us a Google review</a>
    </div>

    <div class="mt-10 grid gap-4 md:grid-cols-2">
      <TestimonialCard name="First review goes here" town="Ayrshire" stars={5} body="Your first real review will land on this page and replace the placeholder. Ask Fraser or Aidan for a review card at the end of the job." />
      <TestimonialCard name="Second review goes here" town="East Ayrshire" stars={5} body="We read every review and reply to every one — including the awkward ones. That’s the deal." />
    </div>

  </section>

  <FacebookFeed
    title="Real work, posted the day it’s finished"
    subtitle="Until the Google reviews roll in, here’s the honest evidence — every completed job goes up on our Facebook the same day. No stock photos, no borrowed before-and-afters."
  />

  <section class="container-x py-12 max-w-4xl">
    <!-- GBP reviews embed instructions (for Gus) -->
    <section class="mt-14 prose-sorn">
      <h2>How we display reviews</h2>
      <p>
        Google doesn’t let us iframe the review list straight in. So on this page every review is copy-pasted by hand — first name and last initial, with a link back to the Google profile so you can check. Once we pass ten reviews we’ll wire up an automated widget (Elfsight, or a light first-party pull of the Places API once a day). Until then, what you see here is dated, attributed and mirrored by us.
      </p>
    </section>
  </section>
  <CTABlock heading="Leave a review, or book a job — either helps." />
</BaseLayout>

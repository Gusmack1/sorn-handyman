---
import BaseLayout from '../../layouts/BaseLayout.astro';
import Breadcrumbs from '../../components/Breadcrumbs.astro';
import AreaCard from '../../components/AreaCard.astro';
import CTABlock from '../../components/CTABlock.astro';
import TrustStrip from '../../components/TrustStrip.astro';
import { areas, BASE, business } from '../../data/business';

const title = 'Areas We Cover — Handyman Across Ayrshire | Sorn Handyman Services';
const description = 'Handyman services across Ayrshire from Sorn — 11 towns covered 24/7, free quotes, no call-out fee. Ayr, Troon, Prestwick, Kilmarnock, Irvine, Mauchline, Kilmaurs, Stewarton, Cumnock, Maybole, Galston and beyond.';
---
<BaseLayout title={title} description={description} canonicalPath="/areas/">
  <Breadcrumbs trail={[{ name: 'Home', href: `${BASE}/` }, { name: 'Areas' }]} />

  <section class="container-x py-12">
    <div class="flex flex-wrap items-center gap-2 text-sm">
      <span class="inline-flex items-center gap-1.5 rounded-full bg-amber-500 text-navy-900 px-3 py-1 font-semibold">
        <span class="h-2 w-2 rounded-full bg-navy-900 animate-pulse"></span>
        Open 24/7
      </span>
      <span class="inline-flex rounded-full border border-navy-900/15 bg-white px-3 py-1 font-medium text-navy-900/80">Fraser + Aidan</span>
    </div>

    <span class="eyebrow mt-5 inline-block">Areas · {areas.length} towns</span>
    <h1 class="mt-3 font-serif text-5xl font-black text-navy-900 max-w-3xl">Handyman cover across Ayrshire.</h1>
    <p class="mt-4 text-lg text-navy-900/75 max-w-2xl">Based in Sorn (KA5) and working a 10-mile radius around every town below. Pick your area for postcodes, local landmarks and service links, or just call — we're open 24/7.</p>

    <div class="mt-6 flex flex-wrap gap-3">
      <a href={`tel:${business.phoneE164}`} class="btn-primary">📞 Call now {business.phone}</a>
      <a href={`https://wa.me/${business.whatsapp.replace('+','')}`} class="btn-secondary bg-[#25D366] !text-white hover:!bg-[#1fb858]">💬 WhatsApp Aidan</a>
    </div>

    <div class="mt-10 grid gap-4 sm:grid-cols-2 lg:grid-cols-3">
      {areas.map((a) => <AreaCard area={a} />)}
    </div>
  </section>

  <TrustStrip />
  <CTABlock heading="Your town not listed? Give us a ring." />
</BaseLayout>

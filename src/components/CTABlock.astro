---
import { business, BASE } from '../data/business';
export interface Props {
  heading?: string;
  sub?: string;
  location?: string;
}
const {
  heading,
  sub = 'One of us answers every call, day or night. Photo on WhatsApp and we can quote you in minutes.',
  location,
} = Astro.props;
const finalHeading = heading || (location ? `Need a handyman in ${location}? Call anytime.` : 'Need a handyman? Call us anytime.');
---
<section class="relative overflow-hidden bg-navy-900 text-white">
  <div class="absolute inset-0 hero-grid-bg opacity-70" aria-hidden></div>
  <div class="absolute -right-32 -top-24 h-80 w-80 rounded-full bg-amber-500/20 blur-3xl" aria-hidden></div>
  <div class="container-x relative py-14 md:py-20 text-center">
    <span class="eyebrow">24/7 · East Ayrshire</span>
    <h2 class="mt-4 font-serif text-4xl md:text-5xl font-black">{finalHeading}</h2>
    <p class="mt-4 max-w-xl mx-auto text-white/75">{sub}</p>
    <div class="mt-8 flex flex-wrap justify-center gap-3">
      <a href={`tel:${business.phoneE164}`} class="btn-primary text-lg">📞 {business.phone}</a>
      <a href={`https://wa.me/${business.whatsapp.replace('+','')}`} class="btn-ghost text-lg">💬 WhatsApp</a>
      <a href={`${BASE}/quote/`} class="btn-secondary text-lg bg-white !text-navy-900 hover:!bg-amber-500">Free quote form</a>
    </div>
  </div>
</section>

---
import { business, BASE } from '../data/business';
import { services, areas } from '../data/business';
const year = new Date().getFullYear();
---
<footer class="mt-24 bg-navy-950 text-cream-100/85" data-print-hide>
  <div class="container-site py-16 grid gap-10 md:grid-cols-4">
    <!-- Brand + Contact -->
    <div class="md:col-span-2">
      <div class="flex items-center gap-3 mb-5">
        <picture>
          <source type="image/webp" srcset={`${BASE}/brand/sorn-logo.webp`} />
          <img
            src={`${BASE}/brand/sorn-logo.png`}
            alt=""
            width="56"
            height="56"
            loading="lazy"
            decoding="async"
            class="h-14 w-14 rounded-full object-cover ring-1 ring-white/15 shadow-elev-2"
          />
        </picture>
        <div class="leading-tight">
          <span class="block font-display text-xl font-bold text-cream-50">Sorn Handyman Services</span>
          <span class="block text-xs uppercase tracking-[0.12em] text-cream-100/60 font-semibold">Father &amp; son · Ayrshire</span>
        </div>
      </div>
      <p class="mb-5 max-w-md text-sm leading-relaxed">
        Fencing, decking, plumbing, joinery, roofing, landscaping &amp; more. No job too small. Free quotes.
      </p>
      <div class="space-y-2 text-cream-50">
        <a href={`tel:${business.phoneE164}`} class="flex items-center gap-2 font-semibold hover:text-amber-300">
          <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M22 16.92v3a2 2 0 0 1-2.18 2 19.79 19.79 0 0 1-8.63-3.07 19.5 19.5 0 0 1-6-6 19.79 19.79 0 0 1-3.07-8.67A2 2 0 0 1 4.11 2h3a2 2 0 0 1 2 1.72c.13.96.37 1.9.72 2.8a2 2 0 0 1-.45 2.11L8.09 9.91a16 16 0 0 0 6 6l1.28-1.28a2 2 0 0 1 2.11-.45c.9.35 1.84.59 2.8.72A2 2 0 0 1 22 16.92z"/></svg>
          Fraser · {business.phone}
        </a>
        <a href={`https://wa.me/${business.whatsapp.replace('+','')}`} class="flex items-center gap-2 hover:text-amber-300" target="_blank" rel="noopener">
          <svg width="18" height="18" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true"><path d="M20.5 3.5A11 11 0 0 0 2.9 17l-1.4 5 5.1-1.4A11 11 0 1 0 20.5 3.5zM12 20a8 8 0 0 1-4-1.1l-.3-.2-3 .8.8-2.9-.2-.3A8 8 0 1 1 12 20z"/></svg>
          Aidan · WhatsApp {business.whatsappDisplay}
        </a>
        <p class="flex items-center gap-2 text-cream-100/70 text-sm">
          <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M21 10c0 7-9 13-9 13s-9-6-9-13a9 9 0 0 1 18 0z"/><circle cx="12" cy="10" r="3"/></svg>
          Based in {business.address.locality}, {business.address.region} · Covers all of Ayrshire
        </p>
      </div>
      <!-- Socials -->
      <div class="mt-5 flex items-center gap-2">
        <a
          href={business.socials.facebook}
          aria-label="Sorn Handyman on Facebook"
          target="_blank"
          rel="noopener"
          class="inline-flex h-9 w-9 items-center justify-center rounded-md bg-white/10 hover:bg-white/20 text-[#4aa3ff]"
        >
          <svg width="18" height="18" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true"><path d="M13.5 21v-8h2.7l.4-3.2h-3.1V7.8c0-.9.3-1.5 1.6-1.5h1.7V3.4c-.3 0-1.3-.1-2.4-.1-2.4 0-4 1.4-4 4.1v2.4H7.7V13h2.7v8h3.1z"/></svg>
        </a>
        <a
          href={business.socials.instagram}
          aria-label="Sorn Handyman on Instagram"
          target="_blank"
          rel="noopener"
          class="inline-flex h-9 w-9 items-center justify-center rounded-md bg-white/10 hover:bg-white/20"
        >
          <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" aria-hidden="true"><rect x="3" y="3" width="18" height="18" rx="5"/><circle cx="12" cy="12" r="4"/><circle cx="17.5" cy="6.5" r="1" fill="currentColor"/></svg>
        </a>
      </div>
    </div>

    <!-- Services -->
    <nav aria-label="Footer services">
      <h3 class="text-cream-50 font-display text-h4 font-semibold mb-4">Services</h3>
      <ul class="space-y-2 text-sm">
        {services.slice(0, 8).map((s) => (
          <li><a class="hover:text-amber-300 transition-colors" href={`${BASE}/services/${s.slug}/`}>{s.name}</a></li>
        ))}
        <li><a class="text-amber-300 font-semibold hover:text-amber-200" href={`${BASE}/services/`}>See all services →</a></li>
      </ul>
    </nav>

    <!-- Areas -->
    <nav aria-label="Footer areas">
      <h3 class="text-cream-50 font-display text-h4 font-semibold mb-4">Areas</h3>
      <ul class="space-y-2 text-sm">
        {areas.slice(0, 8).map((a) => (
          <li><a class="hover:text-amber-300 transition-colors" href={`${BASE}/areas/${a.slug}/`}>Handyman {a.name}</a></li>
        ))}
        <li><a class="text-amber-300 font-semibold hover:text-amber-200" href={`${BASE}/areas/`}>See all areas →</a></li>
      </ul>
    </nav>
  </div>

  <div class="border-t border-white/10">
    <div class="container-site flex flex-col md:flex-row gap-3 justify-between py-6 text-xs text-cream-100/60">
      <p>© {year} Sorn Handyman Services. Father &amp; son. Ayrshire-based.</p>
      <div class="flex gap-4 flex-wrap">
        <a href={`${BASE}/about/`} class="hover:text-amber-300">About</a>
        <a href={`${BASE}/pricing/`} class="hover:text-amber-300">Pricing</a>
        <a href={`${BASE}/contact/`} class="hover:text-amber-300">Contact</a>
        <a href={`${BASE}/quote/`} class="hover:text-amber-300">Free quote</a>
        <a href={business.socials.facebook} class="hover:text-amber-300" rel="noopener" target="_blank">Facebook</a>
      </div>
    </div>
  </div>
</footer>

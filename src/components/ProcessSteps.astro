---
import { processSteps } from '../data/business';
---
<section class="container-site py-16 md:py-24">
  <div class="max-w-2xl">
    <span class="eyebrow">How it works</span>
    <h2 class="mt-4 font-display text-h1 text-navy-800">Three steps. No waiting round.</h2>
  </div>
  <ol class="mt-10 grid gap-6 md:grid-cols-3">
    {processSteps.map((s) => (
      <li class="surface-card relative">
        <span class="absolute -top-4 left-6 inline-flex items-center justify-center h-9 w-9 rounded-full bg-amber-600 text-white font-display font-bold shadow-elev-2" aria-hidden="true">{s.n}</span>
        <h3 class="mt-2 font-display text-h3 text-navy-800">{s.title}</h3>
        <p class="mt-2 text-navy-500 leading-relaxed">{s.body}</p>
      </li>
    ))}
  </ol>
</section>

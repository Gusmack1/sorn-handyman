---
import { business, BASE } from '../data/business';
const { phone, phoneE164 } = business;
const nav = [
  { href: `${BASE}/`, label: 'Home' },
  { href: `${BASE}/services/`, label: 'Services' },
  { href: `${BASE}/areas/`, label: 'Areas' },
  { href: `${BASE}/about/`, label: 'About' },
  { href: `${BASE}/reviews/`, label: 'Reviews' },
  { href: `${BASE}/gallery/`, label: 'Gallery' },
  { href: `${BASE}/blog/`, label: 'Blog' },
  { href: `${BASE}/contact/`, label: 'Contact' },
];
---
<header class="sticky top-0 z-40 bg-white/80 backdrop-blur-md border-b border-navy-900/5">
  <div class="container-x flex items-center justify-between py-3">
    <a href={`${BASE}/`} class="flex items-center gap-2 shrink-0">
      <span class="inline-flex h-10 w-10 items-center justify-center rounded-lg bg-navy-900 text-amber-500 font-black text-sm">24/7</span>
      <span class="font-serif text-xl font-bold text-navy-900 leading-tight">Sorn Handyman</span>
    </a>

    <nav class="hidden lg:flex items-center gap-1 text-sm font-medium text-navy-900">
      {nav.map((n) => (
        <a href={n.href} class="px-3 py-2 rounded-md hover:bg-navy-900/5">{n.label}</a>
      ))}
    </nav>

    <div class="flex items-center gap-2">
      <a
        href="https://www.facebook.com/p/Sorn-Handyman-Services-61573109830217"
        target="_blank"
        rel="noopener"
        aria-label="See our Facebook page"
        class="hidden sm:inline-flex h-9 w-9 items-center justify-center rounded-md text-[#1877F2] hover:bg-navy-900/5"
      >
        <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" width="20" height="20" fill="currentColor" aria-hidden="true">
          <path d="M13.5 21v-8h2.7l.4-3.2h-3.1V7.8c0-.9.3-1.5 1.6-1.5h1.7V3.4c-.3 0-1.3-.1-2.4-.1-2.4 0-4 1.4-4 4.1v2.4H7.7V13h2.7v8h3.1z"/>
        </svg>
      </a>
      <a
        href="https://instagram.com/sornhandyman"
        target="_blank"
        rel="noopener"
        aria-label="See our Instagram"
        class="hidden sm:inline-flex h-9 w-9 items-center justify-center rounded-md hover:bg-navy-900/5"
      >
        <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" width="20" height="20" aria-hidden="true">
          <defs>
            <linearGradient id="igGrad" x1="0" y1="1" x2="1" y2="0">
              <stop offset="0" stop-color="#FEDA77"/>
              <stop offset="0.3" stop-color="#F58529"/>
              <stop offset="0.6" stop-color="#DD2A7B"/>
              <stop offset="0.85" stop-color="#8134AF"/>
              <stop offset="1" stop-color="#515BD4"/>
            </linearGradient>
          </defs>
          <rect x="2.5" y="2.5" width="19" height="19" rx="5" ry="5" fill="url(#igGrad)"/>
          <circle cx="12" cy="12" r="4" fill="none" stroke="#fff" stroke-width="1.7"/>
          <circle cx="17.3" cy="6.7" r="1.1" fill="#fff"/>
        </svg>
      </a>
      <a href={`tel:${phoneE164}`} class="hidden md:inline-flex btn-primary !py-2 !px-4 text-sm">📞 {phone}</a>
      <a href={`${BASE}/quote/`} class="hidden md:inline-flex btn-secondary !py-2 !px-4 text-sm">Send quote request</a>
      <button id="menu-btn" aria-label="Open the menu" aria-expanded="false" aria-controls="mobile-menu" class="lg:hidden inline-flex items-center justify-center rounded-md p-2 text-navy-900 hover:bg-navy-900/5">
        <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M3 6h18M3 12h18M3 18h18"/></svg>
      </button>
    </div>
  </div>

  <div id="mobile-menu" hidden class="lg:hidden border-t border-navy-900/5 bg-white">
    <nav class="container-x py-3 grid grid-cols-2 gap-1 text-sm font-medium">
      {nav.map((n) => (
        <a href={n.href} class="px-3 py-2 rounded-md hover:bg-navy-900/5">{n.label}</a>
      ))}
    </nav>
  </div>
</header>
<script is:inline>
  (function(){
    var b = document.getElementById('menu-btn');
    var m = document.getElementById('mobile-menu');
    if(!b||!m)return;
    b.addEventListener('click', function(){
      var open = !m.hidden;
      m.hidden = open;
      b.setAttribute('aria-expanded', String(!open));
    });
  })();
</script>

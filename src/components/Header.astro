---
import { business, BASE } from '../data/business';
const { phone, phoneE164 } = business;
const nav = [
  { href: `${BASE}/`, label: 'Home' },
  { href: `${BASE}/services/`, label: 'Services' },
  { href: `${BASE}/pricing/`, label: 'Pricing' },
  { href: `${BASE}/areas/`, label: 'Areas' },
  { href: `${BASE}/about/`, label: 'About' },
  { href: `${BASE}/reviews/`, label: 'Reviews' },
  { href: `${BASE}/gallery/`, label: 'Gallery' },
  { href: `${BASE}/blog/`, label: 'Blog' },
  { href: `${BASE}/contact/`, label: 'Contact' },
];
const currentPath = Astro.url.pathname.replace(/\/$/, '') || '/';
---
<header class="sticky top-0 z-40 bg-cream-50 border-b border-navy-100 shadow-elev-1 transition-shadow" data-header>
  <div class="container-site flex items-center justify-between py-3 gap-4">
    <a href={`${BASE}/`} class="flex items-center gap-3 shrink-0 group" aria-label="Sorn Handyman Services — home">
      <picture>
        <source type="image/webp" srcset={`${BASE}/brand/sorn-logo.webp`} />
        <img
          src={`${BASE}/brand/sorn-logo.png`}
          alt=""
          width="48"
          height="48"
          class="h-12 w-12 rounded-full object-cover ring-1 ring-navy-100 shadow-elev-1 transition-transform group-hover:scale-105"
          loading="eager"
          decoding="async"
        />
      </picture>
      <span class="hidden sm:flex flex-col leading-tight">
        <span class="font-display text-lg font-bold text-navy-900">Sorn Handyman</span>
        <span class="text-[11px] uppercase tracking-[0.12em] text-navy-600 font-semibold">Services · Ayrshire</span>
      </span>
    </a>

    <nav class="hidden lg:flex items-center gap-1 text-sm font-medium text-navy-500" aria-label="Primary">
      {nav.map((n) => {
        const nPath = n.href.replace(BASE, '').replace(/\/$/, '') || '/';
        const isActive = nPath === currentPath;
        return (
          <a
            href={n.href}
            aria-current={isActive ? 'page' : undefined}
            class={`px-3 py-2 rounded-md hover:text-amber-700 transition-colors ${isActive ? 'text-navy-800 font-semibold' : ''}`}
          >{n.label}</a>
        );
      })}
    </nav>

    <div class="flex items-center gap-2">
      <a href={`tel:${phoneE164}`} class="hidden md:inline-flex btn-primary btn-sm !rounded-full" aria-label={`Call Fraser on ${phone}`}>
        <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M22 16.92v3a2 2 0 0 1-2.18 2 19.79 19.79 0 0 1-8.63-3.07 19.5 19.5 0 0 1-6-6 19.79 19.79 0 0 1-3.07-8.67A2 2 0 0 1 4.11 2h3a2 2 0 0 1 2 1.72c.13.96.37 1.9.72 2.8a2 2 0 0 1-.45 2.11L8.09 9.91a16 16 0 0 0 6 6l1.28-1.28a2 2 0 0 1 2.11-.45c.9.35 1.84.59 2.8.72A2 2 0 0 1 22 16.92z"/></svg>
        {phone}
      </a>
      <a
        href={`https://wa.me/${business.whatsapp.replace('+','')}`}
        class="hidden md:inline-flex btn-outline btn-sm !rounded-full"
        aria-label="WhatsApp Aidan"
        target="_blank"
        rel="noopener"
      >
        <svg width="16" height="16" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true"><path d="M20.5 3.5A11 11 0 0 0 2.9 17l-1.4 5 5.1-1.4A11 11 0 1 0 20.5 3.5zM12 20a8 8 0 0 1-4-1.1l-.3-.2-3 .8.8-2.9-.2-.3A8 8 0 1 1 12 20zm4.5-5.7c-.2-.1-1.4-.7-1.6-.8-.2-.1-.4-.1-.5.1-.2.2-.6.8-.7.9-.1.2-.3.2-.5.1-.2-.1-1-.4-1.9-1.2-.7-.6-1.2-1.4-1.3-1.6-.1-.2 0-.4.1-.5.1-.1.2-.3.3-.4.1-.1.2-.2.2-.4 0-.1 0-.3-.1-.4-.1-.1-.5-1.2-.7-1.7-.2-.4-.4-.4-.5-.4h-.5a1 1 0 0 0-.7.3c-.2.3-.9.9-.9 2.2s.9 2.5 1 2.7c.1.2 1.8 2.8 4.4 3.9.6.3 1.1.4 1.5.5.6.2 1.2.2 1.7.1.5-.1 1.4-.6 1.6-1.1.2-.5.2-1 .1-1.1z"/></svg>
        WhatsApp Aidan
      </a>
      <button id="menu-btn" aria-label="Open menu" aria-expanded="false" aria-controls="mobile-menu" class="lg:hidden inline-flex items-center justify-center rounded-md p-2 text-navy-700 hover:bg-navy-50 transition-colors" style="min-width:44px;min-height:44px;">
        <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" aria-hidden="true"><path d="M3 6h18M3 12h18M3 18h18"/></svg>
      </button>
    </div>
  </div>

  <!-- Mobile full-screen sheet -->
  <div id="mobile-menu" hidden class="lg:hidden fixed inset-0 z-50 bg-navy-800 text-cream-50">
    <div class="flex items-center justify-between px-5 pt-4 pb-3 border-b border-white/10">
      <div class="flex items-center gap-3">
        <picture>
          <source type="image/webp" srcset={`${BASE}/brand/sorn-logo.webp`} />
          <img src={`${BASE}/brand/sorn-logo.png`} alt="" width="40" height="40" loading="lazy" decoding="async" class="h-10 w-10 rounded-full ring-1 ring-white/20" />
        </picture>
        <span class="font-display text-lg font-semibold">Sorn Handyman</span>
      </div>
      <button id="menu-close" aria-label="Close menu" class="inline-flex items-center justify-center rounded-md p-2 hover:bg-white/10" style="min-width:44px;min-height:44px;">
        <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" aria-hidden="true"><path d="M18 6 6 18M6 6l12 12"/></svg>
      </button>
    </div>
    <nav class="px-5 py-6 flex flex-col" aria-label="Mobile">
      {nav.map((n) => (
        <a
          href={n.href}
          class="py-4 text-xl font-display font-semibold border-b border-white/10 hover:text-amber-300"
          style="min-height:48px;display:flex;align-items:center;"
        >{n.label}</a>
      ))}
    </nav>
    <div class="px-5 pt-4 pb-8 flex flex-col gap-3">
      <a href={`tel:${phoneE164}`} class="btn-primary btn-lg w-full justify-center">
        <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M22 16.92v3a2 2 0 0 1-2.18 2 19.79 19.79 0 0 1-8.63-3.07 19.5 19.5 0 0 1-6-6 19.79 19.79 0 0 1-3.07-8.67A2 2 0 0 1 4.11 2h3a2 2 0 0 1 2 1.72c.13.96.37 1.9.72 2.8a2 2 0 0 1-.45 2.11L8.09 9.91a16 16 0 0 0 6 6l1.28-1.28a2 2 0 0 1 2.11-.45c.9.35 1.84.59 2.8.72A2 2 0 0 1 22 16.92z"/></svg>
        Call Fraser {phone}
      </a>
      <a href={`https://wa.me/${business.whatsapp.replace('+','')}`} class="btn-ghost-dark btn-lg w-full justify-center" target="_blank" rel="noopener" aria-label="WhatsApp Aidan">
        WhatsApp Aidan
      </a>
    </div>
  </div>
</header>
<script is:inline>
  (function(){
    var btn = document.getElementById('menu-btn');
    var close = document.getElementById('menu-close');
    var menu = document.getElementById('mobile-menu');
    if(!btn || !menu) return;
    function open(){ menu.hidden = false; btn.setAttribute('aria-expanded','true'); document.documentElement.style.overflow='hidden'; }
    function shut(){ menu.hidden = true; btn.setAttribute('aria-expanded','false'); document.documentElement.style.overflow=''; }
    btn.addEventListener('click', open);
    if(close) close.addEventListener('click', shut);
    menu.querySelectorAll('a').forEach(function(a){ a.addEventListener('click', shut); });
    // Header shadow on scroll
    var header = document.querySelector('[data-header]');
    if(header){
      var onScroll = function(){
        if(window.scrollY > 16){ header.classList.add('shadow-elev-1'); }
        else { header.classList.remove('shadow-elev-1'); }
      };
      document.addEventListener('scroll', onScroll, { passive: true });
      onScroll();
    }
  })();
</script>

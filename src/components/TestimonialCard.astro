---
export interface Props {
  name: string;
  town: string;
  stars?: number;
  body: string;
  job?: string;
}
const { name, town, stars = 5, body, job } = Astro.props;
---
<figure class="surface-card">
  <div class="flex items-center gap-0.5 text-amber-500" aria-label={`${stars} out of 5 stars`}>
    {Array.from({ length: stars }).map(() => (
      <svg width="18" height="18" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true"><path d="m12 2 3.09 6.26L22 9.27l-5 4.87 1.18 6.88L12 17.77l-6.18 3.25L7 14.14 2 9.27l6.91-1.01L12 2z"/></svg>
    ))}
    {Array.from({ length: 5 - stars }).map(() => (
      <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" class="text-navy-100" aria-hidden="true"><path d="m12 2 3.09 6.26L22 9.27l-5 4.87 1.18 6.88L12 17.77l-6.18 3.25L7 14.14 2 9.27l6.91-1.01L12 2z"/></svg>
    ))}
  </div>
  <svg width="28" height="28" viewBox="0 0 24 24" fill="currentColor" class="mt-3 text-amber-400" aria-hidden="true"><path d="M7.17 6C4.35 6 2 8.4 2 11.33 2 14.56 4.57 17 7.82 17L9 14.5C7.48 14.5 6 13.01 6 11.5c0-1.27.83-2.5 2.17-2.5V6zm10 0c-2.82 0-5.17 2.4-5.17 5.33 0 3.23 2.57 5.67 5.82 5.67L19 14.5c-1.52 0-3-1.49-3-3 0-1.27.83-2.5 2.17-2.5V6z"/></svg>
  <blockquote class="mt-2 font-display text-h4 leading-snug text-navy-800">{body}</blockquote>
  <figcaption class="mt-3 text-sm text-navy-500">
    <span class="font-semibold text-navy-700">{name}</span> · {town}{job ? ` · ${job}` : ''}
  </figcaption>
</figure>

---
import { business, BASE } from '../data/business';
export interface Props {
  eyebrow?: string;
  headline?: string;
  sub?: string;
  showCtas?: boolean;
}
const {
  eyebrow = 'Sorn · East Ayrshire · 24/7 availability',
  headline = 'Maintenance, Repairs & Home Improvements',
  sub = 'Fraser and Aidan cover all of Ayrshire. FREE no-obligation quote — call or WhatsApp today.',
  showCtas = true,
} = Astro.props;
---
<section class="relative overflow-hidden bg-cream-50 border-b border-navy-100" aria-labelledby="hero-title">
  <!-- Subtle brand-navy gradient wash behind the logo for depth (no background image competes with the mark) -->
  <div class="absolute inset-0 bg-gradient-to-b from-cream-50 via-cream-50 to-cream-100" aria-hidden="true"></div>
  <div class="absolute inset-x-0 top-0 h-1.5 bg-brand-navy" aria-hidden="true"></div>

  <div class="container-site relative z-10 py-14 md:py-20 lg:py-24">
    <div class="max-w-4xl mx-auto text-center motion-safe:animate-fade-in-up">
      <!-- MAIN HERO: horizontal logo is the marquee mark -->
      <picture>
        <source type="image/webp" srcset={`${BASE}/sorn-logo-horizontal.webp`} />
        <img
          src={`${BASE}/sorn-logo-horizontal.png`}
          alt="Sorn Handyman Services — Maintenance, Repairs & Home Improvements logo"
          width="2000"
          height="739"
          loading="eager"
          decoding="async"
          fetchpriority="high"
          class="mx-auto w-full max-w-md md:max-w-2xl lg:max-w-3xl h-auto drop-shadow-[0_8px_24px_rgba(15,30,61,0.12)]"
        />
      </picture>

      <span class="eyebrow mt-8 inline-flex">
        <span class="inline-block h-2 w-2 rounded-full bg-amber-500 animate-pulse" aria-hidden="true"></span>
        {eyebrow}
      </span>

      <h1
        id="hero-title"
        class="mt-4 font-display font-bold text-brand-navy leading-[1.1]"
        style="font-size: clamp(1.875rem, 3.2vw + 1rem, 3.25rem); letter-spacing: -0.015em;"
      >
        {headline}
      </h1>

      <p class="mt-5 mx-auto max-w-2xl text-navy-700 text-base md:text-lg leading-relaxed">
        {sub}
      </p>

      {showCtas && (
        <div class="mt-8 flex flex-wrap justify-center gap-3">
          <a href={`tel:${business.phoneE164}`} class="btn-primary btn-lg" aria-label={`Call ${business.phone}`}>
            <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M22 16.92v3a2 2 0 0 1-2.18 2 19.79 19.79 0 0 1-8.63-3.07 19.5 19.5 0 0 1-6-6 19.79 19.79 0 0 1-3.07-8.67A2 2 0 0 1 4.11 2h3a2 2 0 0 1 2 1.72c.13.96.37 1.9.72 2.8a2 2 0 0 1-.45 2.11L8.09 9.91a16 16 0 0 0 6 6l1.28-1.28a2 2 0 0 1 2.11-.45c.9.35 1.84.59 2.8.72A2 2 0 0 1 22 16.92z"/></svg>
            Call {business.phone}
          </a>
          <a
            href={`https://wa.me/${business.whatsapp.replace('+','')}`}
            class="btn-outline btn-lg"
            target="_blank"
            rel="noopener"
            aria-label="WhatsApp Aidan"
          >
            <svg width="18" height="18" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true"><path d="M20.5 3.5A11 11 0 0 0 2.9 17l-1.4 5 5.1-1.4A11 11 0 1 0 20.5 3.5zM12 20a8 8 0 0 1-4-1.1l-.3-.2-3 .8.8-2.9-.2-.3A8 8 0 1 1 12 20z"/></svg>
            WhatsApp Aidan
          </a>
          <a href={`${BASE}/quote/`} class="btn-ghost btn-lg">
            Get a FREE quote
            <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M5 12h14M12 5l7 7-7 7"/></svg>
          </a>
        </div>
      )}

      <!-- Trust micro-bar (Facebook-grounded only) -->
      <ul class="mt-10 flex flex-wrap justify-center gap-x-6 gap-y-2 text-sm font-medium text-navy-600">
        <li class="flex items-center gap-2">
          <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" aria-hidden="true"><path d="M21 10c0 7-9 13-9 13s-9-6-9-13a9 9 0 0 1 18 0z"/><circle cx="12" cy="10" r="3"/></svg>
          All of Ayrshire
        </li>
        <li class="flex items-center gap-2">
          <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" aria-hidden="true"><circle cx="12" cy="12" r="10"/><path d="M12 6v6l4 2"/></svg>
          24/7 availability
        </li>
        <li class="flex items-center gap-2">
          <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" aria-hidden="true"><path d="M21 15a2 2 0 0 1-2 2H7l-4 4V5a2 2 0 0 1 2-2h14a2 2 0 0 1 2 2z"/></svg>
          FREE no-obligation quotes
        </li>
      </ul>
    </div>
  </div>

  <!-- Down-arrow bounce indicator -->
  <a href="#services" aria-label="Scroll to services" class="absolute bottom-4 left-1/2 -translate-x-1/2 text-navy-500 hover:text-brand-navy motion-safe:animate-bounce-soft hidden md:inline-flex">
    <svg width="28" height="28" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M12 5v14M5 12l7 7 7-7"/></svg>
  </a>
</section>

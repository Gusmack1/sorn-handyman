---
import { business, BASE } from '../data/business';
export interface Props {
  eyebrow?: string;
  headline?: string;
  sub?: string;
  showCtas?: boolean;
}
const {
  eyebrow = 'Father & son · All of Ayrshire · Free quotes',
  headline = "Ayrshire's father-and-son handyman team",
  sub = 'Fencing, decking, plumbing, joinery, roofing, landscaping & more. No job too small. Free quotes.',
  showCtas = true,
} = Astro.props;
---
<section class="relative overflow-hidden hero-gradient-critical" style="min-height: 90vh;">
  <!-- Backdrop image with subtle pan -->
  <img
    src={`${BASE}/brand/hero.png`}
    alt=""
    aria-hidden="true"
    class="absolute inset-0 w-full h-full object-cover opacity-40 motion-safe:animate-hero-pan"
    loading="eager"
    decoding="async"
    fetchpriority="high"
    width="2560"
    height="1440"
  />
  <!-- Navy gradient overlay — left is AA-clean for text -->
  <div class="absolute inset-0 bg-gradient-to-r from-navy-900/90 via-navy-800/70 to-navy-800/30" aria-hidden="true"></div>
  <div class="absolute inset-0 bg-gradient-to-b from-transparent via-transparent to-navy-900/60" aria-hidden="true"></div>

  <!-- Floating logo chip (decorative, desktop only) -->
  <div class="hidden md:block absolute top-10 right-10 z-10 motion-safe:animate-float" aria-hidden="true">
    <div class="flex items-center gap-3 bg-cream-50/10 backdrop-blur-md border border-white/20 rounded-full pl-2 pr-5 py-2 shadow-elev-3">
      <img src={`${BASE}/brand/sorn-logo.png`} alt="" width="48" height="48" class="h-12 w-12 rounded-full object-cover ring-2 ring-white/30" />
      <div class="leading-tight">
        <p class="text-cream-50 font-display text-sm font-semibold">Sorn Handyman</p>
        <p class="text-cream-100 text-[11px] uppercase tracking-wider">Est. Ayrshire</p>
      </div>
    </div>
  </div>

  <div class="container-site relative z-10 flex flex-col justify-center" style="min-height: 90vh;">
    <div class="max-w-3xl py-24 md:py-28 motion-safe:animate-fade-in-up">
      <span class="eyebrow !bg-amber-50/10 !text-amber-300 !ring-amber-300/30">
        <span class="inline-block h-2 w-2 rounded-full bg-amber-400 animate-pulse" aria-hidden="true"></span>
        {eyebrow}
      </span>
      <h1 class="mt-5 font-display font-bold text-cream-50 leading-[1.05]" style="font-size: clamp(2.5rem, 5.5vw + 1rem, 4.5rem); letter-spacing: -0.02em;">
        {headline}
      </h1>
      <p class="mt-5 text-cream-100/90 max-w-2xl text-lg md:text-xl leading-relaxed">
        {sub}
      </p>

      {showCtas && (
        <div class="mt-8 flex flex-wrap gap-3">
          <a href={`${BASE}/quote/`} class="btn-primary btn-lg">
            Get a free quote
            <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M5 12h14M12 5l7 7-7 7"/></svg>
          </a>
          <a href={`tel:${business.phoneE164}`} class="btn-ghost-dark btn-lg">
            <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M22 16.92v3a2 2 0 0 1-2.18 2 19.79 19.79 0 0 1-8.63-3.07 19.5 19.5 0 0 1-6-6 19.79 19.79 0 0 1-3.07-8.67A2 2 0 0 1 4.11 2h3a2 2 0 0 1 2 1.72c.13.96.37 1.9.72 2.8a2 2 0 0 1-.45 2.11L8.09 9.91a16 16 0 0 0 6 6l1.28-1.28a2 2 0 0 1 2.11-.45c.9.35 1.84.59 2.8.72A2 2 0 0 1 22 16.92z"/></svg>
            Call Fraser {business.phone}
          </a>
        </div>
      )}

      <!-- Trust micro-bar (Facebook-grounded only) -->
      <ul class="mt-10 flex flex-wrap gap-x-6 gap-y-2 text-sm font-medium text-cream-100/80">
        <li class="flex items-center gap-2">
          <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" aria-hidden="true"><circle cx="12" cy="8" r="4"/><path d="M6 21a6 6 0 0 1 12 0"/></svg>
          Father &amp; son
        </li>
        <li class="flex items-center gap-2">
          <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" aria-hidden="true"><path d="M21 10c0 7-9 13-9 13s-9-6-9-13a9 9 0 0 1 18 0z"/><circle cx="12" cy="10" r="3"/></svg>
          All of Ayrshire
        </li>
        <li class="flex items-center gap-2">
          <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" aria-hidden="true"><path d="M21 15a2 2 0 0 1-2 2H7l-4 4V5a2 2 0 0 1 2-2h14a2 2 0 0 1 2 2z"/></svg>
          Free quotes · fast response
        </li>
      </ul>
    </div>
  </div>

  <!-- Down-arrow bounce indicator -->
  <a href="#services" aria-label="Scroll to services" class="absolute bottom-6 left-1/2 -translate-x-1/2 text-cream-100/70 hover:text-cream-50 motion-safe:animate-bounce-soft hidden md:inline-flex">
    <svg width="28" height="28" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M12 5v14M5 12l7 7 7-7"/></svg>
  </a>
</section>

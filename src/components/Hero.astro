---
import { business, BASE } from '../data/business';
export interface Props {
  eyebrow?: string;
  headline?: string;
  sub?: string;
  showCtas?: boolean;
}
const {
  eyebrow = 'Open 24 hours · 7 days a week',
  headline = '24/7 Handyman in East Ayrshire — call 07900 255876 anytime.',
  sub = 'Fraser and Aidan. One of us answers every call, day or night.',
  showCtas = true,
} = Astro.props;
---
<section class="relative overflow-hidden bg-navy-900 text-white">
  <div class="absolute inset-0 hero-grid-bg opacity-80" aria-hidden></div>
  <div class="absolute -top-20 -right-20 h-80 w-80 rounded-full bg-amber-500/20 blur-3xl" aria-hidden></div>
  <div class="absolute -bottom-24 -left-10 h-96 w-96 rounded-full bg-amber-500/10 blur-3xl" aria-hidden></div>

  <div class="container-x relative py-16 md:py-24 grid gap-10 lg:grid-cols-5 items-center">
    <div class="lg:col-span-3">
      <span class="eyebrow"><span class="inline-block h-2 w-2 rounded-full bg-amber-500 animate-pulse"></span> {eyebrow}</span>
      <h1 class="mt-4 font-serif font-black leading-[1.05] text-4xl sm:text-5xl lg:text-6xl">
        {headline}
      </h1>
      <p class="mt-5 max-w-xl text-lg text-white/80">{sub}</p>

      {showCtas && (
        <div class="mt-8 flex flex-wrap gap-3">
          <a href={`tel:${business.phoneE164}`} class="btn-primary text-lg">📞 Call {business.phone}</a>
          <a href={`https://wa.me/${business.whatsapp.replace('+','')}`} class="btn-ghost text-lg">💬 WhatsApp</a>
          <a href={`${BASE}/quote/`} class="btn-secondary text-lg bg-white !text-navy-900 hover:!bg-amber-500">Free written quote →</a>
        </div>
      )}

      <dl class="mt-10 grid grid-cols-2 gap-6 max-w-lg text-left">
        <div>
          <dt class="text-xs uppercase tracking-wider text-white/50">Trades covered</dt>
          <dd class="font-serif text-3xl font-bold text-amber-500">14</dd>
        </div>
        <div>
          <dt class="text-xs uppercase tracking-wider text-white/50">Response</dt>
          <dd class="font-serif text-3xl font-bold text-amber-500">&lt;1h</dd>
        </div>
      </dl>
    </div>

    <div class="lg:col-span-2">
      <div class="relative aspect-[4/5] rounded-2xl overflow-hidden ring-1 ring-white/10 bg-gradient-to-br from-navy-800 to-navy-950 shadow-2xl">
        <!-- TODO: replace with real Fraser+Aidan photo at public/img/team.jpg -->
        <img src={`${BASE}/img/team.svg`} alt="Fraser and Aidan — Sorn Handyman Services" class="absolute inset-0 h-full w-full object-cover" loading="eager" decoding="async" width="600" height="750" />
        <div class="absolute bottom-0 inset-x-0 p-5 bg-gradient-to-t from-black/80 to-transparent">
          <p class="text-sm text-white/80">Fraser & Aidan</p>
          <p class="text-white font-semibold text-lg">Sorn-based. 24/7.</p>
        </div>
        <span class="absolute top-4 left-4 inline-flex items-center gap-1 rounded-full bg-amber-500 px-3 py-1 text-xs font-black text-navy-900">LIVE · 24/7</span>
      </div>
    </div>
  </div>
</section>

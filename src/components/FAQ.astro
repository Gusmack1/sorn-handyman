---
import { faqs as defaultFaqs } from '../data/business';
export interface Props {
  faqs?: { q: string; a: string }[];
  heading?: string;
}
const { faqs = defaultFaqs, heading = 'Questions we get a lot' } = Astro.props;
---
<section class="container-x py-16">
  <div class="max-w-2xl">
    <span class="eyebrow">FAQ</span>
    <h2 class="mt-4 font-serif text-4xl font-bold text-navy-900">{heading}</h2>
  </div>
  <div class="mt-8 grid gap-3 max-w-3xl">
    {faqs.map((f) => (
      <details data-faq class="card py-4 open:shadow-md">
        <summary class="flex items-start justify-between gap-4 font-serif text-lg font-semibold text-navy-900">
          <span>{f.q}</span>
          <span class="faq-chev shrink-0 h-6 w-6 rounded-full bg-amber-500/15 text-amber-600 flex items-center justify-center font-black">+</span>
        </summary>
        <p class="mt-3 text-navy-900/75 leading-relaxed">{f.a}</p>
      </details>
    ))}
  </div>
</section>

---
import { faqs as defaultFaqs } from '../data/business';
export interface Props {
  faqs?: { q: string; a: string }[];
  heading?: string;
}
const { faqs = defaultFaqs, heading = 'Questions we get a lot' } = Astro.props;
---
<section class="container-site py-16 md:py-24 cv-auto">
  <div class="max-w-2xl">
    <span class="eyebrow">FAQ</span>
    <h2 class="mt-4 font-display text-h1 text-navy-800">{heading}</h2>
  </div>
  <div class="mt-8 grid gap-3 max-w-3xl">
    {faqs.map((f) => (
      <details data-faq class="surface-card !p-5 open:shadow-elev-2">
        <summary class="flex items-start justify-between gap-4 font-display text-h4 font-semibold text-navy-700">
          <span>{f.q}</span>
          <span class="faq-chev shrink-0 h-7 w-7 rounded-full bg-amber-50 text-amber-600 flex items-center justify-center font-bold ring-1 ring-amber-100">+</span>
        </summary>
        <p class="mt-3 text-navy-500 leading-relaxed">{f.a}</p>
      </details>
    ))}
  </div>
</section>

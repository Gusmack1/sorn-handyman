---
// Shared "Related posts" / "Recent local work" block.
// Renders a heading + a grid of Post cards. Used by area, service, and blog pages.
import { BASE } from '../data/business';
import type { Post } from '../data/posts';

interface Props {
  posts: Post[];
  heading?: string;
  eyebrow?: string;
  variant?: 'plain' | 'tinted';
}

const { posts, heading = 'Related posts', eyebrow, variant = 'tinted' } = Astro.props as Props;
---
{posts && posts.length > 0 && (
  <section class={variant === 'tinted' ? 'bg-navy-50/60 border-y border-navy-900/5' : ''}>
    <div class="container-x py-12">
      {eyebrow && <span class="eyebrow">{eyebrow}</span>}
      <h2 class="mt-3 font-serif text-3xl font-bold text-navy-900">{heading}</h2>
      <div class="mt-6 grid gap-4 sm:grid-cols-2 lg:grid-cols-3">
        {posts.map((p) => (
          <article class="group relative rounded-2xl border border-navy-900/10 bg-white p-5 hover:border-amber-500 transition-colors">
            <div class="text-xs font-semibold uppercase tracking-wider text-amber-600">{p.area}</div>
            <h3 class="mt-2 font-serif text-lg font-bold text-navy-900 leading-snug">
              <a href={`${BASE}/blog/${p.slug}/`} class="after:absolute after:inset-0 group-hover:text-amber-700">{p.title}</a>
            </h3>
            <p class="mt-2 text-sm text-navy-900/70 line-clamp-3">{p.description}</p>
            <div class="mt-3 text-xs text-navy-900/50">{p.dateDisplay} &middot; {p.readMinutes} min read</div>
          </article>
        ))}
      </div>
    </div>
  </section>
)}

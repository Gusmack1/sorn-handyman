---
import { BASE } from '../data/business';
import type { Area } from '../data/business';
export interface Props {
  area: Area;
}
const { area } = Astro.props;
---
<a href={`${BASE}/areas/${area.slug}/`} class="card group flex flex-col gap-1">
  <div class="flex items-baseline justify-between">
    <h3 class="font-serif text-lg font-bold text-navy-900">Handyman in {area.name}</h3>
    {area.postcode && <span class="text-xs font-medium text-navy-900/50">{area.postcode}</span>}
  </div>
  <p class="text-sm text-navy-900/70 line-clamp-3">{area.intro}</p>
  <div class="mt-2 flex items-center justify-between text-xs font-medium text-navy-900/60">
    <span>{area.distance}</span>
    <span class="group-hover:text-amber-600 group-hover:translate-x-0.5 transition">View →</span>
  </div>
</a>

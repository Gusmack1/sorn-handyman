---
// Zero-JS-until-needed before/after slider. Progressive enhancement via inline JS.
export interface Props {
  before: string;
  after: string;
  altBefore?: string;
  altAfter?: string;
  label?: string;
}
const { before, after, altBefore, altAfter, label } = Astro.props;
const beforeAlt = altBefore || (label ? `Before: ${label}` : 'Before — job in progress');
const afterAlt = altAfter || (label ? `After: ${label}` : 'After — completed job');
---
<figure class="ba-slider relative aspect-[4/3] w-full rounded-2xl ring-1 ring-navy-100 shadow-elev-2 bg-cream-100" role="img" aria-label={label ? `Before and after: ${label}` : 'Before and after comparison'}>
  <img src={before} alt={beforeAlt} loading="lazy" decoding="async" />
  <div class="ba-after">
    <img src={after} alt={afterAlt} loading="lazy" decoding="async" />
  </div>
  <div class="ba-handle" aria-hidden="true"></div>
  {label && <figcaption class="absolute top-3 left-3 rounded-full bg-navy-800/85 backdrop-blur-sm px-3 py-1 text-xs font-semibold text-cream-50">{label}</figcaption>}
</figure>
<script is:inline>
  (function(){
    document.querySelectorAll('.ba-slider').forEach(function(el){
      var after = el.querySelector('.ba-after');
      var handle = el.querySelector('.ba-handle');
      function setPos(clientX){
        var r = el.getBoundingClientRect();
        var x = Math.max(0, Math.min(100, ((clientX - r.left) / r.width) * 100));
        after.style.clipPath = 'inset(0 0 0 ' + x + '%)';
        handle.style.left = x + '%';
      }
      var dragging = false;
      el.addEventListener('pointerdown', function(e){ dragging=true; el.setPointerCapture(e.pointerId); setPos(e.clientX); });
      el.addEventListener('pointermove', function(e){ if(dragging) setPos(e.clientX); });
      el.addEventListener('pointerup', function(){ dragging=false; });
      el.addEventListener('pointercancel', function(){ dragging=false; });
    });
  })();
</script>

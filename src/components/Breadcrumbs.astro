---
import SchemaBlock from './SchemaBlock.astro';
import { business, BASE } from '../data/business';
// Accepts either `trail: {name, href}[]` (legacy) OR `items: {label, href}[]`.
// Both shapes render identically and emit BreadcrumbList JSON-LD.
export interface Props {
  trail?: { name: string; href?: string }[];
  items?: { label: string; href?: string }[];
}
const { trail, items: itemsProp } = Astro.props;
const source = trail
  ? trail.map((t) => ({ label: t.name, href: t.href }))
  : (itemsProp || []);
// `business.siteUrl` already includes the Astro `base` (e.g. `/sorn-handyman`).
// Callers pass href with BASE baked in (e.g. `/sorn-handyman/services/`) so that
// visible <a href> links work under the GitHub Pages base path. For the JSON-LD
// absolute URL we must avoid double-prefixing — strip the BASE from the href
// before joining with siteUrl, otherwise we emit `/sorn-handyman/sorn-handyman/…`.
const siteUrl = business.siteUrl.replace(/\/$/, '');
const baseNorm = (BASE || '').replace(/\/$/, '');
function toAbsolute(href: string): string {
  if (href.startsWith('http')) return href;
  let path = href;
  if (baseNorm && (path === baseNorm || path.startsWith(`${baseNorm}/`))) {
    path = path.slice(baseNorm.length) || '/';
  }
  if (!path.startsWith('/')) path = `/${path}`;
  return `${siteUrl}${path}`;
}
const listItems = source.map((t, i) => ({
  '@type': 'ListItem',
  position: i + 1,
  name: t.label,
  ...(t.href ? { item: toAbsolute(t.href) } : {}),
}));
const schema = {
  '@context': 'https://schema.org',
  '@type': 'BreadcrumbList',
  itemListElement: listItems,
};
---
<nav aria-label="Breadcrumb" class="container-site pt-6 text-sm text-navy-400">
  <ol class="flex flex-wrap items-center gap-x-1.5">
    {source.map((t, i) => (
      <li class="flex items-center gap-1.5">
        {t.href ? <a href={t.href} class="hover:text-amber-700 transition-colors">{t.label}</a> : <span class="text-navy-700 font-medium">{t.label}</span>}
        {i < source.length - 1 && <span aria-hidden class="text-navy-200">›</span>}
      </li>
    ))}
  </ol>
  <SchemaBlock schema={schema} />
</nav>

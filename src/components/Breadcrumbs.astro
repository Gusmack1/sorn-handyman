---
import SchemaBlock from './SchemaBlock.astro';
import { business } from '../data/business';
export interface Props {
  trail: { name: string; href?: string }[];
}
const { trail } = Astro.props;
const siteUrl = business.siteUrl.replace(/\/$/, '');
const items = trail.map((t, i) => ({
  '@type': 'ListItem',
  position: i + 1,
  name: t.name,
  ...(t.href ? { item: t.href.startsWith('http') ? t.href : `${siteUrl}${t.href}` } : {}),
}));
const schema = {
  '@context': 'https://schema.org',
  '@type': 'BreadcrumbList',
  itemListElement: items,
};
---
<nav aria-label="Breadcrumb" class="container-x pt-6 text-sm text-navy-900/60">
  <ol class="flex flex-wrap items-center gap-x-1.5">
    {trail.map((t, i) => (
      <li class="flex items-center gap-1.5">
        {t.href ? <a href={t.href} class="hover:text-amber-600">{t.name}</a> : <span class="text-navy-900/80">{t.name}</span>}
        {i < trail.length - 1 && <span aria-hidden class="text-navy-900/30">›</span>}
      </li>
    ))}
  </ol>
  <SchemaBlock schema={schema} />
</nav>

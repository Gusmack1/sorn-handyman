---
import { business, BASE } from '../data/business';
---
<div id="sticky-call" data-print-hide class="md:hidden fixed bottom-0 inset-x-0 z-40 bg-navy-900 text-cream-50 shadow-elev-4 border-t border-navy-950">
  <div class="grid grid-cols-3 divide-x divide-white/10 text-center">
    <a href={`tel:${business.phoneE164}`} class="flex flex-col items-center justify-center gap-0.5 py-3 hover:bg-navy-800 active:bg-navy-800" aria-label={`Call Fraser on ${business.phone}`}>
      <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M22 16.92v3a2 2 0 0 1-2.18 2 19.79 19.79 0 0 1-8.63-3.07 19.5 19.5 0 0 1-6-6 19.79 19.79 0 0 1-3.07-8.67A2 2 0 0 1 4.11 2h3a2 2 0 0 1 2 1.72c.13.96.37 1.9.72 2.8a2 2 0 0 1-.45 2.11L8.09 9.91a16 16 0 0 0 6 6l1.28-1.28a2 2 0 0 1 2.11-.45c.9.35 1.84.59 2.8.72A2 2 0 0 1 22 16.92z"/></svg>
      <span class="text-[11px] font-semibold uppercase tracking-wide">Call Fraser</span>
    </a>
    <a href={`https://wa.me/${business.whatsapp.replace('+','')}?text=Hi%20Sorn%20Handyman%2C%20can%20I%20get%20a%20quote%20for%3A%20`} class="flex flex-col items-center justify-center gap-0.5 py-3 hover:bg-navy-800 active:bg-navy-800">
      <svg width="20" height="20" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true"><path d="M20.5 3.5A11 11 0 0 0 2.9 17l-1.4 5 5.1-1.4A11 11 0 1 0 20.5 3.5zM12 20a8 8 0 0 1-4-1.1l-.3-.2-3 .8.8-2.9-.2-.3A8 8 0 1 1 12 20z"/></svg>
      <span class="text-[11px] font-semibold uppercase tracking-wide">WhatsApp</span>
    </a>
    <a href={`${BASE}/quote/`} class="flex flex-col items-center justify-center gap-0.5 py-3 bg-amber-600 text-white hover:bg-amber-700">
      <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M14 2H6a2 2 0 0 0-2 2v16a2 2 0 0 0 2 2h12a2 2 0 0 0 2-2V8l-6-6z"/><path d="M14 2v6h6"/><path d="m9 14 2 2 4-4"/></svg>
      <span class="text-[11px] font-semibold uppercase tracking-wide">Free quote</span>
    </a>
  </div>
</div>

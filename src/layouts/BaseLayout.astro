---
import '../styles/global.css';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
import StickyCallBar from '../components/StickyCallBar.astro';
import WhatsAppFab from '../components/WhatsAppFab.astro';
import SchemaBlock from '../components/SchemaBlock.astro';
import { business, BASE } from '../data/business';
import { coreBusiness } from '../lib/schema';

export interface Props {
  title: string;
  description: string;
  canonicalPath?: string;
  ogImage?: string;
  ogType?: 'website' | 'article';
  noindex?: boolean;
  extraSchema?: any;
}

const {
  title,
  description,
  canonicalPath = '/',
  ogImage,
  ogType = 'website',
  noindex = false,
  extraSchema,
} = Astro.props;

const siteUrl = business.siteUrl.replace(/\/$/, '');
// Collapse any accidental double slashes after the scheme (e.g. siteUrl ending in '/'
// combined with a leading '/' in canonicalPath) while preserving the '//' after 'https:'.
const canonical = `${siteUrl}${canonicalPath.startsWith('/') ? canonicalPath : '/' + canonicalPath}`
  .replace(/([^:])\/\/+/g, '$1/');
// Brand OG fallback — /sorn-handyman/brand/og.webp (PR #20 WebP export).
const og = ogImage || `${siteUrl}/brand/og.webp`;

const core = coreBusiness(canonical);
---
<!doctype html>
<html lang="en-GB" data-theme="light" style="color-scheme: light;">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1, viewport-fit=cover" />
    <meta name="theme-color" content="#FBF8F2" />
    <meta name="color-scheme" content="light only" />
    <title>{title}</title>
    <meta name="description" content={description} />
    <link rel="canonical" href={canonical} />
    {noindex && <meta name="robots" content="noindex, nofollow" />}

    <!-- hreflang -->
    <link rel="alternate" hreflang="en-GB" href={canonical} />
    <link rel="alternate" hreflang="x-default" href={canonical} />

    <!-- Open Graph -->
    <meta property="og:type" content={ogType} />
    <meta property="og:site_name" content="Sorn Handyman Services" />
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:url" content={canonical} />
    <meta property="og:image" content={og} />
    <meta property="og:image:alt" content={title} />
    <meta property="og:image:width" content="1200" />
    <meta property="og:image:height" content="630" />
    <meta property="og:locale" content="en_GB" />

    <!-- Twitter -->
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={title} />
    <meta name="twitter:description" content={description} />
    <meta name="twitter:image" content={og} />
    <meta name="twitter:image:alt" content={title} />

    <!-- Icons -->
    <link rel="icon" type="image/svg+xml" href={`${BASE}/favicon.svg`} />
    <link rel="icon" type="image/png" href={`${BASE}/icons/favicon-32.png`} sizes="32x32" />
    <link rel="icon" type="image/png" href={`${BASE}/icons/favicon-16.png`} sizes="16x16" />
    <link rel="apple-touch-icon" sizes="180x180" href={`${BASE}/icons/apple-touch-icon.png`} />
    <link rel="mask-icon" href={`${BASE}/favicon.svg`} color="#143249" />
    <link rel="manifest" href={`${BASE}/manifest.webmanifest`} />

    <!-- Fonts (Bunny Fonts, GDPR-safe). Preload-then-apply pattern avoids
         render-blocking without leaving an unused preload. -->
    <link rel="preconnect" href="https://fonts.bunny.net" crossorigin />
    <link rel="dns-prefetch" href="https://fonts.bunny.net" />
    <link
      rel="preload"
      as="style"
      href="https://fonts.bunny.net/css?family=inter-tight:400,500,600,700|bricolage-grotesque:500,600,700&display=swap"
      onload="this.onload=null;this.rel='stylesheet'"
    />
    <noscript>
      <link
        rel="stylesheet"
        href="https://fonts.bunny.net/css?family=inter-tight:400,500,600,700|bricolage-grotesque:500,600,700&display=swap"
      />
    </noscript>

    <!-- Critical CSS to kill CLS on hero -->
    <style>
      .hero-gradient-critical {
        background-image:
          radial-gradient(1200px 600px at 85% -20%, rgba(242, 160, 61, 0.22), transparent 60%),
          linear-gradient(125deg, #0F2A3F 0%, #143249 55%, #8F500A 140%);
        color: #FBF8F2;
      }
      body { background: #FBF8F2; color: #143249; }
    </style>

    <!-- Business schema (every page) -->
    <SchemaBlock schema={core} />
    {extraSchema && <SchemaBlock schema={extraSchema} />}

    <!-- Lightweight website + sitelinks search schema -->
    <SchemaBlock schema={{
      '@context': 'https://schema.org',
      '@type': 'WebSite',
      url: siteUrl,
      name: 'Sorn Handyman Services',
      publisher: { '@id': `${siteUrl}/#business` },
    }} />
  </head>
  <body class="min-h-screen flex flex-col">
    <a href="#main" class="sr-only focus:not-sr-only focus:fixed focus:top-2 focus:left-2 focus:z-50 focus:bg-amber-600 focus:text-white focus:px-3 focus:py-2 focus:rounded-md focus:shadow-elev-2">Skip to content</a>
    <Header />
    <main id="main" class="flex-1">
      <slot />
    </main>
    <Footer />
    <StickyCallBar />
    <WhatsAppFab />
  </body>
</html>
